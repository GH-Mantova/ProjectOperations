# Shared
NODE_ENV=development

# Database
POSTGRES_DB=project_operations
POSTGRES_USER=project_ops
POSTGRES_PASSWORD=project_ops
DATABASE_URL=postgresql://project_ops:project_ops@localhost:5432/project_operations?schema=public

# API
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Client portal (PR #83 + #83.1)
# Optional dedicated secrets for the client-portal JWT subsystem. If left
# blank, the auth config derives portal-specific secrets via SHA-256 of the
# staff secrets so portal tokens cannot be verified against the staff secret.
# Set distinct values in production.
PORTAL_JWT_ACCESS_SECRET=
PORTAL_JWT_REFRESH_SECRET=
PORTAL_JWT_RESET_SECRET=
PORTAL_JWT_ACCESS_TTL=30m
# Public URL portal users hit (used in invite + reset email links).
PORTAL_PUBLIC_URL=http://localhost:5173

# SharePoint — set SHAREPOINT_MODE=live (or graph) to enable the Graph API
# adapter. AZURE_* env names are the canonical credential set; the legacy
# SHAREPOINT_TENANT_ID / CLIENT_ID / CLIENT_SECRET names still work as a
# fallback so existing deployments keep running.
SHAREPOINT_MODE=mock
SHAREPOINT_SITE_ID=project-operations-site
SHAREPOINT_LIBRARY_ID=project-operations-library
SHAREPOINT_ROOT_FOLDER=Project Operations
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# SSO (Microsoft 365 / Entra)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
SSO_ENABLED=false
VITE_SSO_ENABLED=false
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# Xero accounting integration (PR #86)
# Required to use the Xero connect/sync/invoice endpoints. Register an
# OAuth2 app at https://developer.xero.com/app/manage and set the redirect
# URI to match XERO_REDIRECT_URI exactly.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/v1/xero/callback
# Space-separated list. Defaults below cover contacts + transactions + the
# offline_access scope needed for refresh tokens.
XERO_SCOPES=openid profile email accounting.contacts accounting.transactions offline_access

# AI (Tendering Assistant chat — §5A.1 PRs 6 + 7, plus legacy scope drafting)
# At least one provider key is required for the floating chat to work. Both
# fall back from this env var to the encrypted column on platform_config —
# admin-saved (in the UI) takes precedence over env. Get keys at
# https://console.anthropic.com and https://platform.openai.com/api-keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides — set these to switch model tier without code
# changes. Env wins over PlatformConfig.getModel() so a deployment-time
# switch flips both the chat and (post-migration) AI scope drafting.
# Anthropic default: claude-sonnet-4-6. OpenAI default: gpt-5.4-mini.
ANTHROPIC_MODEL=
OPENAI_MODEL=
# AES-256 secret for encrypting Anthropic keys at rest in platform_config.
# Must be long + random in production. Changing this after keys are saved
# renders previously saved keys unreadable.
PLATFORM_CONFIG_SECRET=change-me-in-production

# Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
