# Shared
NODE_ENV=development

# Database
POSTGRES_DB=project_operations
POSTGRES_USER=project_ops
POSTGRES_PASSWORD=project_ops
DATABASE_URL=postgresql://project_ops:project_ops@localhost:5432/project_operations?schema=public

# API
API_PORT=3000
API_PREFIX=api/v1
# CORS_ORIGIN accepts a comma-separated list of allowed origins. The API echoes
# the matching origin on credentialed requests (never "*"). During a custom-
# domain cutover, list the new domain first (used as the canonical portal URL)
# and keep the legacy host alongside it, e.g.:
#   CORS_ORIGIN=https://operations.initialservices.net,https://<name>.azurestaticapps.net
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Auth endpoint rate limiting (per client IP, in-memory, single instance).
# AUTH_THROTTLE_TTL is the window in SECONDS. AUTH_THROTTLE_LIMIT applies to
# login-style routes (login/entra/sso/reset-password); the refresh route gets
# its own bucket via AUTH_THROTTLE_REFRESH_LIMIT.
# Production (pilot) values = the defaults below.
# CI / local E2E runs log in many times per minute from one IP — set
# AUTH_THROTTLE_LIMIT=1000 and AUTH_THROTTLE_REFRESH_LIMIT=1000 there
# (see .github/workflows/playwright.yml).
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5
AUTH_THROTTLE_REFRESH_LIMIT=30

# Client portal (PR #83 + #83.1)
# Optional dedicated secrets for the client-portal JWT subsystem. If left
# blank, the auth config derives portal-specific secrets via SHA-256 of the
# staff secrets so portal tokens cannot be verified against the staff secret.
# Set distinct values in production.
PORTAL_JWT_ACCESS_SECRET=
PORTAL_JWT_REFRESH_SECRET=
PORTAL_JWT_RESET_SECRET=
PORTAL_JWT_ACCESS_TTL=30m
# Public URL portal users hit (used in invite + reset email links).
PORTAL_PUBLIC_URL=http://localhost:5173

# SharePoint — set SHAREPOINT_MODE=live (or graph) to enable the Graph API
# adapter. AZURE_* env names are the canonical credential set; the legacy
# SHAREPOINT_TENANT_ID / CLIENT_ID / CLIENT_SECRET names still work as a
# fallback so existing deployments keep running.
SHAREPOINT_MODE=mock

# Correspondence Hub (PR #215) — mock-mode adapter simulates outbound mail
# and inbound reply parsing for the per-record correspondence panel.
# Live Microsoft Graph adapter is a follow-up and requires additional
# Entra Mail.Read / Mail.Read.Shared permissions.
CORRESPONDENCE_MODE=mock
SHAREPOINT_SITE_ID=project-operations-site
SHAREPOINT_LIBRARY_ID=project-operations-library
SHAREPOINT_ROOT_FOLDER=Project Operations
# PR-64 — live-mode site resolution. When SHAREPOINT_SITE_ID /
# SHAREPOINT_LIBRARY_ID above are unset, the API resolves the actual
# IDs via Graph from these three values on first use, then caches.
# Required for live mode unless the explicit ID overrides are set.
SHAREPOINT_SITE_HOSTNAME=initialservices.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/Initialservices
SHAREPOINT_LIBRARY_NAME=Documents
# DEPRECATED — use the SharePoint folder mappings admin screen
# (Admin → Platform → SharePoint folder mappings). The DB mapping for
# entity_type=TENDER wins; this env var is a fallback for envs whose DB
# has no mapping row (fresh QA envs, older tests) and will be removed in
# a follow-up PR once the DB path is proven in prod. New entity mappings
# (jobs, safety incidents, workers, ...) are DB-only — never env vars.
SHAREPOINT_TENDERS_ROOT=Project Operations/Tenders
# Auth mode for the SharePoint / Graph adapter.
#   client-secret    — use AZURE_CLIENT_SECRET below (default; required for
#                      local dev, CI, and any non-Azure host).
#   managed-identity — use the Azure host's managed identity (App Service /
#                      Container Apps / VM). AZURE_CLIENT_SECRET is NOT read
#                      in this mode. See docs/runbooks/graph-managed-identity.md
#                      for the one-time Azure-side setup (a Global Admin has
#                      to grant Sites.ReadWrite.All and Mail.Send to the
#                      identity via PowerShell — there is no portal UI).
# Explicit selection over DefaultAzureCredential's silent fallback chain.
SHAREPOINT_AUTH_MODE=client-secret
# Optional: set when the App Service uses a *user-assigned* managed identity.
# Leave blank to use the system-assigned identity. Ignored when
# SHAREPOINT_AUTH_MODE=client-secret.
AZURE_MANAGED_IDENTITY_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Azure Mail.Send (optional — falls back to SHAREPOINT_* if unset)
# Set these when the Mail.Send app registration differs from the SharePoint
# one (e.g. tighter scopes, separate audit trail). When any of TENANT_ID /
# CLIENT_ID / CLIENT_SECRET is blank, OutlookEmailProvider reuses the
# matching SHAREPOINT_* value so existing deployments keep working.
# AZURE_MAIL_SENDER_USER_ID is the mailbox (UPN or object id) that owns the
# sent message — defaults to the per-tenant emailProviderConfig row when not
# set here.
AZURE_MAIL_TENANT_ID=
AZURE_MAIL_CLIENT_ID=
AZURE_MAIL_CLIENT_SECRET=
AZURE_MAIL_SENDER_USER_ID=

# PR-216 — Calendar Sync. mock = local ledger only (default), live =
# Microsoft Graph (Calendars.ReadWrite) — not yet implemented; needs
# added Entra permission + sign-off before flipping to live.
CALENDAR_MODE=mock

# SSO (Microsoft 365 / Entra)
# NOTE: /auth/sso does NOT auto-provision. An authenticated Entra user with no
# matching internal user is gated (ENTRA_NOT_REGISTERED) and can submit an
# access request via /auth/request-access; an admin approves/denies from the
# admin "Access requests" tab.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
SSO_ENABLED=false
VITE_SSO_ENABLED=false
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# Where admin notifications for access requests are emailed. Defaults to
# marco@initialservices.net if unset.
ACCESS_REQUEST_NOTIFY_EMAIL=marco@initialservices.net

# Xero accounting integration (PR #86)
# Required to use the Xero connect/sync/invoice endpoints. Register an
# OAuth2 app at https://developer.xero.com/app/manage and set the redirect
# URI to match XERO_REDIRECT_URI exactly.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/v1/xero/callback
# Space-separated list. Defaults below cover contacts + transactions + the
# offline_access scope needed for refresh tokens.
XERO_SCOPES=openid profile email accounting.contacts accounting.transactions offline_access

# AI (Tendering Assistant chat — §5A.1 PRs 6/7/9, plus legacy scope drafting)
# §5A.1 PR 9: company keys are now configured exclusively via the
# /admin/ai-settings UI (Company tab → API Keys). The legacy env var path is
# no longer read at runtime — the values below are kept for reference only.
# ANTHROPIC_API_KEY=  # NO LONGER READ — set via UI
# OPENAI_API_KEY=     # NO LONGER READ — set via UI

# Optional model overrides — set these to switch model tier without code
# changes. Env wins over PlatformConfig.getModel() so a deployment-time
# switch flips both the chat and AI scope drafting.
# Anthropic default: claude-sonnet-4-6. OpenAI default: gpt-5.4-mini.
ANTHROPIC_MODEL=
OPENAI_MODEL=

# §5A.1 PR 9 — REQUIRED for app start.
# Master key for AI provider key encryption (AES-256-GCM). 32 bytes
# expressed as 64 hex chars. Generate with: openssl rand -hex 32
# NEVER reuse across environments. Loss = re-entry of all keys via UI.
BYOK_ENCRYPTION_KEY=

# Legacy AES-256 secret used by pre-PR-9 platform_config columns. No longer
# read at runtime; kept for reference only. Drop in a future cleanup PR.
# PLATFORM_CONFIG_SECRET=change-me-in-production

# Rates canonical source (Rates B-slice-2 cutover).
# Which store answers rate lookups through the RateResolverService seam.
#   legacy    — read the 8 Estimate*Rate tables (default; pre-cutover behaviour).
#   ratetable — read the flexible RateTable / RateColumn / RateRow model,
#               seeded byte-identically to legacy in PR #552. Legacy is used
#               only as a fallback for slugs the flexible model doesn't cover.
# DO NOT flip to `ratetable` in an environment until `assertRateParity` shows
# clean agreement on a full pricing cycle. Ships OFF (legacy) on purpose:
# flipping this is what makes it safe to eventually drop the legacy tables.
RATES_CANONICAL_SOURCE=legacy

# Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
