# Shared
NODE_ENV=development

# Database
POSTGRES_DB=project_operations
POSTGRES_USER=project_ops
POSTGRES_PASSWORD=project_ops
DATABASE_URL=postgresql://project_ops:project_ops@localhost:5432/project_operations?schema=public

# API
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SHAREPOINT_MODE=mock
SHAREPOINT_SITE_ID=project-operations-site
SHAREPOINT_LIBRARY_ID=project-operations-library
SHAREPOINT_ROOT_FOLDER=Project Operations
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# SSO (Microsoft 365 / Entra)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
SSO_ENABLED=false
VITE_SSO_ENABLED=false
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# AI (Claude scope drafting)
# If set, used as a fallback when no key has been saved through the admin UI.
# The admin-saved key (in the platform_config table) takes precedence.
ANTHROPIC_API_KEY=
# AES-256 secret for encrypting Anthropic keys at rest in platform_config.
# Must be long + random in production. Changing this after keys are saved
# renders previously saved keys unreadable.
PLATFORM_CONFIG_SECRET=change-me-in-production

# Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
