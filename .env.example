# Shared
NODE_ENV=development

# Database
POSTGRES_DB=project_operations
POSTGRES_USER=project_ops
POSTGRES_PASSWORD=project_ops
DATABASE_URL=postgresql://project_ops:project_ops@localhost:5432/project_operations?schema=public

# API
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SHAREPOINT_MODE=mock
SHAREPOINT_SITE_ID=project-operations-site
SHAREPOINT_LIBRARY_ID=project-operations-library
SHAREPOINT_ROOT_FOLDER=Project Operations
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
