node_modules
dist
coverage
.turbo
.pnpm-store
.env
.env.local
.env.*.local
apps/api/generated
# Self-contained API bundle produced by deploy.yml (pnpm deploy output)
/deploy-api/
apps/api/dist/
apps/web/dist/
# PR #146 — local mock storage for SharePoint adapter (dev-only file persistence).
# Pattern matches wherever the storage dir lands (default is
# apps/api/.local-storage/ since both `pnpm dev` and `pnpm seed` run from there,
# but cover any cwd a future caller picks).
**/.local-storage/
*.js.map
*.log
Desktop.ini
.claude/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Compiled JS artifacts in src (tsc without --noEmit pollutes src/)
apps/web/src/**/*.js
apps/web/src/**/*.js.map

# vite.config.ts is authoritative; tsc used to emit a vite.config.js here
# that clobbered the ESM shim. Keep it out of git.
apps/web/vite.config.js

# PR #156 — TypeScript incremental build cache is machine-specific and
# regenerated by tsc on every build. Was previously tracked and showed
# as perpetually modified in `git status`.
apps/web/*.tsbuildinfo
apps/api/*.tsbuildinfo

# PR #156 — transient smoke-test output directory; the .js files inside
# are tsc-emitted from `apps/web/src/pages/tendering-page-helpers.ts` and
# its tests, and were perpetually modified in `git status`.
apps/web/.tmp-smoke/

# Local scratch directory for generated PDFs during manual verification.
/tmp-outputs/

# Sensitive: real client/pricing data — never commit
Company Templates/
company-templates/
reference-templates/

# PR-watcher runtime state — machine-local, not for version control.
scripts/pr-watcher/.reviewed-prs.json
scripts/pr-watcher/.reviewed-prs.json.tmp
scripts/pr-watcher/.watcher.lock

# PR-prompt watcher bookkeeping� never commit these.
# The watcher creates and moves files between these folders to track state;
# committing them causes phantom dirty trees on branch switches.
docs/pr-prompts/*-ready.md
docs/pr-prompts/processed/
docs/pr-prompts/failed/
docs/pr-prompts/paused/
docs/pr-prompts/blocked/
docs/pr-prompts/awaiting-review/
docs/pr-prompts/reviewed/
docs/pr-prompts/needs-marco/

# Generated by `pnpm xero:import-contacts` — local-only run artefact.
apps/api/scripts/xero-import-report.md
