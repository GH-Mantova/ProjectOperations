// Transactional ledger of charges / payments against a supplier's credit
// account. The headline limit (`creditLimit`) and approval flag
// (`creditApproved`) live on SubcontractorSupplier â€" this table records the
// movements that determine the *current balance* and *remaining credit*.
// Amounts are stored unsigned; `entryType` carries the sign (charge = owed
// to supplier, payment = paid).
model SupplierCreditEntry {
  id              String                @id @default(cuid())
  subcontractorId String                @map("subcontractor_id")
  subcontractor   SubcontractorSupplier @relation("SupplierCreditEntries", fields: [subcontractorId], references: [id], onDelete: Cascade)
  entryDate       DateTime              @map("entry_date")
  entryType       String                @map("entry_type") // "charge" | "payment"
  amount          Decimal               @db.Decimal(12, 2)
  reference       String?
  note            String?
  createdAt       DateTime              @default(now()) @map("created_at")
  createdById     String                @map("created_by_id")
  createdBy       User                  @relation("SupplierCreditEntryCreator", fields: [createdById], references: [id])

  @@index([subcontractorId])
  @@index([entryDate])
  @@map("supplier_credit_entries")
}

