// ─── ERP gap A/commercial — punch / snag / defect list ───────────────
// Job-scoped handover / make-good close-out list (Procore parity).
// Raised from ad-hoc inspections OR linked back to a FormSubmission /
// corrective action row when the item was generated from a checklist.
// Status graph: OPEN → IN_PROGRESS → CLOSED. Cascade delete on job.
model PunchItem {
  id           String          @id @default(cuid())
  jobId        String          @map("job_id")
  title        String
  description  String?
  location     String?
  status       String          @default("OPEN")
  raisedById   String          @map("raised_by_id")
  assignedToId String?         @map("assigned_to_id")
  dueAt        DateTime?       @map("due_at")
  closedAt     DateTime?       @map("closed_at")
  closedById   String?         @map("closed_by_id")
  closureNote  String?         @map("closure_note")
  photoUrl     String?         @map("photo_url")
  submissionId String?         @map("submission_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  job          Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  raisedBy     User            @relation("PunchItemRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)
  assignedTo   User?           @relation("PunchItemAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  closedBy     User?           @relation("PunchItemClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  submission   FormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([assignedToId, status])
  @@index([dueAt])
  @@map("punch_items")
}

