// PR #18 â€" unified communications panel. One table replaces the three
// legacy Overview-tab feeds (Activity timeline / Clarifications &
// Communications / Follow-ups). Legacy tables stay one release cycle
// for safety; a follow-up PR drops them.
model TenderEntry {
  id         String    @id @default(cuid())
  tenderId   String    @map("tender_id")
  tender     Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  type       String // 'note' | 'rfi' | 'email' | 'call' | 'meeting' | 'follow_up' | 'self_reminder' | 'task'
