  subcontractorId  String?                @map("subcontractor_id")
  subcontractor    SubcontractorSupplier? @relation("SubInsurances", fields: [subcontractorId], references: [id], onDelete: Cascade)
  // Company profile ownership â€" polymorphic reuse for OUR own insurances
  // (public liability, workers comp, professional indemnity). Same alert
  // path as subcontractors; no auto-block.
  companyProfileId String?                @map("company_profile_id")
  companyProfile   CompanyProfile?        @relation("CompanyInsurances", fields: [companyProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime               @default(now()) @map("created_at")
