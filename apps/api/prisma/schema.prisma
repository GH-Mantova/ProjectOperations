model AssetCategory {
  id                              String   @id @default(cuid())
  name                            String   @unique
  code                            String?  @unique
  description                     String?
  isActive                        Boolean  @default(true) @map("is_active")
  // Waste transport cost engine R3 T-0 — category-level fallbacks. An Asset
  // resolves fuel/capacity in the order: specific Asset field → its
  // AssetCategory default → null. Fuel consumption is per-truck (Marco
  // 2026-07-15) so category defaults are a convenience for bulk-seeding a
  // fleet, not a business rule.
  defaultFuelConsumptionLPer100km Decimal? @map("default_fuel_consumption_l_per_100km") @db.Decimal(6, 2)
  defaultNominalLoadTonnes        Decimal? @map("default_nominal_load_tonnes") @db.Decimal(8, 2)
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")
