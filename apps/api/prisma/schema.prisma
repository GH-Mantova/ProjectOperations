  @@index([clientId])
  @@index([isAwarded])
  @@map("tender_clients")
}

enum TenderPricingBasis {
  DOCUMENTS
  CLIENT_REQUEST
  IDENTIFIED_RISK
}

// A tender-scope package (e.g. Asbestos, Demolition, Concrete Cutting, Civil).
// disciplineItemId points at a GlobalListItem in the `tender-package-disciplines`
// list — Director-configurable, not a hardcoded enum.
model TenderPackage {
  id               String                @id @default(cuid())
  tenderId         String                @map("tender_id")
  disciplineItemId String                @map("discipline_item_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  tender           Tender                @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  disciplineItem   GlobalListItem        @relation("TenderPackageDiscipline", fields: [disciplineItemId], references: [id], onDelete: Restrict)
  clientPackages   TenderClientPackage[]

  @@unique([tenderId, disciplineItemId])
  @@index([tenderId])
  @@index([disciplineItemId])
  @@map("tender_packages")
}

// Builder × package matrix cell — which client is pricing which package,
// on what basis, with optional note (e.g. what document/request/risk drove it).
model TenderClientPackage {
  id              String             @id @default(cuid())
  tenderClientId  String             @map("tender_client_id")
  tenderPackageId String             @map("tender_package_id")
  pricingBasis    TenderPricingBasis @default(DOCUMENTS) @map("pricing_basis")
  basisNote       String?            @map("basis_note")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  tenderClient    TenderClient       @relation(fields: [tenderClientId], references: [id], onDelete: Cascade)
  tenderPackage   TenderPackage      @relation(fields: [tenderPackageId], references: [id], onDelete: Cascade)

  @@unique([tenderClientId, tenderPackageId])
  @@index([tenderClientId])
  @@index([tenderPackageId])
  @@map("tender_client_packages")
}

model TenderNote {
  id           String   @id @default(cuid())
  tenderId     String   @map("tender_id")
  authorUserId String?  @map("author_user_id")
