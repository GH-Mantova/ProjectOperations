}

// PR #621 -- public / kiosk / QR-code capture (no-login form submission)
// mode: "public" = single-submit tokenised link; "kiosk" = repeated shared-device submit
model FormPublicLink {
  id              String           @id @default(cuid())
  templateId      String           @map("template_id")
  template        FormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  token           String           @unique
  // mode: public | kiosk
  mode            String           @default("public")
  isActive        Boolean          @default(true) @map("is_active")
  expiresAt       DateTime?        @map("expires_at")
  // optional context pre-applied to every submission via this link
  siteId          String?          @map("site_id")
  jobId           String?          @map("job_id")
  // optional cap on total public submissions before auto-deactivation
  maxSubmissions  Int?             @map("max_submissions")
  // denormalized count updated by the service; avoids a COUNT(*) on every submit
  submissionCount Int              @default(0) @map("submission_count")
  label           String?
  createdById     String?          @map("created_by_id")
  createdBy       User?            @relation("FormPublicLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  submissions     FormSubmission[]

  @@index([token])
  @@index([templateId])
  @@map("form_public_links")
}

model FormSubmissionValue {
