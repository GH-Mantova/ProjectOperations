  correspondences    CorrespondenceThread[] @relation("JobCorrespondence")

  @@index([clientId])
  @@index([status])
  @@index([projectManagerId])
  @@index([supervisorId])
  @@index([survivingProjectId])
  @@map("jobs")
}

model JobConversion {
