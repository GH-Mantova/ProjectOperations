// â"€â"€ Resource Allocation module (PR #40) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// WorkerProfile is the HR/compliance-facing staff record. It is separate from
// the scheduler-facing Worker model (which carries crew/shift/availability
// wiring). A WorkerProfile becomes an internal login once Mobile Access is
// provisioned (internalUserId â†' User).
//
// ProjectAllocation joins either a WorkerProfile OR an Asset onto a Project
// over a date range. Type constraints are enforced in the service layer so
// the table stays a flat join.

model WorkerProfile {
  id                       String                 @id @default(cuid())
  firstName                String                 @map("first_name")
  lastName                 String                 @map("last_name")
  preferredName            String?                @map("preferred_name")
  role                     String
  phone                    String?
  email                    String?                @unique
  emergencyContactName     String?                @map("emergency_contact_name")
  emergencyContactPhone    String?                @map("emergency_contact_phone")
  licenceNumber            String?                @map("licence_number")
  licenceClass             String?                @map("licence_class")
  ticketNumbers            String?                @map("ticket_numbers")
  hasMobileAccess          Boolean                @default(false) @map("has_mobile_access")
  internalUserId           String?                @unique @map("internal_user_id")
  internalUser             User?                  @relation(fields: [internalUserId], references: [id], onDelete: SetNull)
  isActive                 Boolean                @default(true) @map("is_active")
  locationConsent          Boolean                @default(false) @map("location_consent")
  locationConsentAt        DateTime?              @map("location_consent_at")
  locationConsentRevokedAt DateTime?              @map("location_consent_revoked_at")
  allocations              ProjectAllocation[]
  scheduleAllocations      ScheduleAllocation[]
  preStartChecklists       PreStartChecklist[]
  timesheets               Timesheet[]
  qualifications           WorkerQualification[]
  ganttTasks               GanttTask[]
  locationLogs             WorkerLocationLog[]
  leaves                   WorkerLeave[]
  unavailabilities         WorkerUnavailability[]
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([lastName, firstName])
  @@map("worker_profiles")
}

model ProjectAllocation {
  id                  String               @id @default(cuid())
  projectId           String               @map("project_id")
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                AllocationTargetType
  workerProfileId     String?              @map("worker_profile_id")
  workerProfile       WorkerProfile?       @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  assetId             String?              @map("asset_id")
  asset               Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  roleOnProject       String?              @map("role_on_project")
  startDate           DateTime             @map("start_date")
  endDate             DateTime?            @map("end_date")
  notes               String?
  createdById         String               @map("created_by_id")
  createdBy           User                 @relation("ProjectAllocationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  preStartChecklists  PreStartChecklist[]
  timesheets          Timesheet[]
  competencyOverrides CompetencyOverride[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([projectId, type])
  @@index([workerProfileId, startDate])
  @@index([assetId, startDate])
  @@map("project_allocations")
}

// â"€â"€ PR-452 Â§9 Day-grain ScheduleAllocation â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Canonical day-grain allocation alongside the existing range-based
// `ProjectAllocation` (which stays wired to timesheets / pre-starts /
// competency-gate). The scheduler grid consumes this table. Eligibility
// and conflict flags are COMPUTED on read â€" never denormalised here.
//
// `overrideReason` is populated when a `scheduler.manage` user allocates
// an ineligible worker via the showAll path; the matching AuditLog row
// is action `schedule.unqualified_override`.

enum ScheduleTargetType {
  WORKER
  ASSET
}

model ScheduleAllocation {
  id              String             @id @default(cuid())
  date            DateTime           @db.Date
  projectId       String             @map("project_id")
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetType      ScheduleTargetType @map("target_type")
  workerProfileId String?            @map("worker_profile_id")
  workerProfile   WorkerProfile?     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  assetId         String?            @map("asset_id")
  asset           Asset?             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  jobRoleId       String?            @map("job_role_id")
  jobRole         JobRole?           @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  note            String?
  overrideReason  String?            @map("override_reason")
  createdById     String             @map("created_by_id")
  createdBy       User               @relation("ScheduleAllocationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([date, projectId, workerProfileId, jobRoleId], name: "schedule_alloc_worker_uniq")
  @@unique([date, projectId, assetId], name: "schedule_alloc_asset_uniq")
  @@index([date])
  @@index([projectId, date])
  @@index([workerProfileId, date])
  @@index([assetId, date])
  @@map("schedule_allocations")
}

// â"€â"€ Competency gate override (PR-279 enforcement) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// When the gate would block a workerâ†'project allocation (worker missing or
// holding only expired copies of a required qualType on Project.requiredQualifications),
// an authorised allocator (Admin/SuperUser or holder of resources.manage) can
// proceed by supplying an override payload with a mandatory reason. Each row
// here is the authoritative record of one such override â€" keyed to the
// allocation it unblocked, listing the qual codes that were missing/expired
// at decision time. An AuditLog row of action `allocation.unqualified_override`
// is written in parallel to keep the org-wide audit trail intact.

model CompetencyOverride {
  id               String            @id @default(cuid())
  allocationId     String            @map("allocation_id")
  allocation       ProjectAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  projectId        String            @map("project_id")
  workerProfileId  String            @map("worker_profile_id")
  // Snapshot of the qualType codes the gate flagged at override time. Stored
  // as arrays (not joined to Competency rows) because requiredQualifications
  // itself is a String[] of qualType codes, and a code may not have a matching
  // Competency catalog row.
  missingQualTypes String[]          @default([]) @map("missing_qual_types")
  expiredQualTypes String[]          @default([]) @map("expired_qual_types")
  reason           String
  overriddenById   String            @map("overridden_by_id")
  overriddenBy     User              @relation("CompetencyOverrideActor", fields: [overriddenById], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now()) @map("created_at")

  @@index([allocationId])
  @@index([projectId])
  @@index([workerProfileId])
  @@index([overriddenById])
  @@map("competency_overrides")
}

// â"€â"€ Field Worker Experience (PR #41) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// PreStartChecklist + Timesheet are field-submitted records keyed to a worker
// (WorkerProfile) + their allocation on a project. DRAFT records are editable
// by the worker; SUBMITTED locks the record and fires a notification + a
// project activity log entry. Timesheet has an additional APPROVED state set
// by a user with field.manage.

enum PreStartStatus {
  DRAFT
  SUBMITTED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model PreStartChecklist {
  id                 String            @id @default(cuid())
  projectId          String            @map("project_id")
  project            Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerProfileId    String            @map("worker_profile_id")
  workerProfile      WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  allocationId       String            @map("allocation_id")
  allocation         ProjectAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  date               DateTime
  status             PreStartStatus    @default(DRAFT)
  supervisorName     String?           @map("supervisor_name")
  supervisorSignedAt DateTime?         @map("supervisor_signed_at")

  siteHazardsAcknowledged Boolean @default(false) @map("site_hazards_acknowledged")
  hazardNotes             String? @map("hazard_notes")

  ppeHelmet     Boolean @default(false) @map("ppe_helmet")
  ppeGloves     Boolean @default(false) @map("ppe_gloves")
  ppeBoots      Boolean @default(false) @map("ppe_boots")
  ppeHighVis    Boolean @default(false) @map("ppe_high_vis")
  ppeRespirator Boolean @default(false) @map("ppe_respirator")
  ppeOther      String? @map("ppe_other")

  plantChecksCompleted Boolean @default(false) @map("plant_checks_completed")
  plantCheckNotes      String? @map("plant_check_notes")

  fitForWork            Boolean   @default(false) @map("fit_for_work")
  fitForWorkDeclaration String?   @map("fit_for_work_declaration")
  workerSignature       String?   @map("worker_signature")
  workerSignedAt        DateTime? @map("worker_signed_at")

  asbEnclosureInspection Boolean? @map("asb_enclosure_inspection")
  asbAirMonitoring       Boolean? @map("asb_air_monitoring")
  asbDeconOperational    Boolean? @map("asb_decon_operational")

  civExcavationPermit     Boolean? @map("civ_excavation_permit")
  civUndergroundClearance Boolean? @map("civ_underground_clearance")

  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([workerProfileId, allocationId, date])
  @@index([projectId, date])
  @@index([workerProfileId, date])
  @@index([status])
  @@map("pre_start_checklists")
}

model Timesheet {
  id               String            @id @default(cuid())
  projectId        String            @map("project_id")
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerProfileId  String            @map("worker_profile_id")
  workerProfile    WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  allocationId     String            @map("allocation_id")
  allocation       ProjectAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  date             DateTime
  hoursWorked      Decimal           @map("hours_worked") @db.Decimal(4, 2)
  breakMinutes     Int               @default(0) @map("break_minutes")
  description      String?
  clockOnTime      DateTime?         @map("clock_on_time")
  clockOffTime     DateTime?         @map("clock_off_time")
  clockOnLat       Decimal?          @map("clock_on_lat") @db.Decimal(9, 6)
  clockOnLng       Decimal?          @map("clock_on_lng") @db.Decimal(9, 6)
  clockOnAccuracy  Decimal?          @map("clock_on_accuracy") @db.Decimal(8, 2)
  clockOffLat      Decimal?          @map("clock_off_lat") @db.Decimal(9, 6)
  clockOffLng      Decimal?          @map("clock_off_lng") @db.Decimal(9, 6)
  clockOffAccuracy Decimal?          @map("clock_off_accuracy") @db.Decimal(8, 2)
  // ERP gap C — geofence audit flags. Boolean is nullable so pre-geofence
  // rows (and rows without GPS) stay distinguishable from a genuine "outside
  // the geofence" reading. clockOnGeofenceId is set only when the point fell
  // inside an active geofence at the time of evaluation; if the site has no
  // geofence configured, both remain null.
  clockOnInGeofence  Boolean?        @map("clock_on_in_geofence")
  clockOffInGeofence Boolean?        @map("clock_off_in_geofence")
  clockOnGeofenceId  String?         @map("clock_on_geofence_id")
  clockOnGeofence    SiteGeofence?   @relation("TimesheetClockOnGeofence", fields: [clockOnGeofenceId], references: [id], onDelete: SetNull)
  clockOffGeofenceId String?         @map("clock_off_geofence_id")
  clockOffGeofence   SiteGeofence?   @relation("TimesheetClockOffGeofence", fields: [clockOffGeofenceId], references: [id], onDelete: SetNull)
  status           TimesheetStatus   @default(DRAFT)
  submittedAt      DateTime?         @map("submitted_at")
  approvedById     String?           @map("approved_by_id")
  approvedBy       User?             @relation("TimesheetApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?         @map("approved_at")
  rejectedReason   String?           @map("rejected_reason")
  rejectedById     String?           @map("rejected_by_id")
  rejectedBy       User?             @relation("TimesheetRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt       DateTime?         @map("rejected_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@unique([workerProfileId, allocationId, date])
  @@index([projectId, date])
  @@index([workerProfileId, date])
  @@index([status])
  @@map("timesheets")
}

// â"€â"€ Scope cards (PR A2, 2026-05-16) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// User-named groupings of scope items. Replaces the legacy fixed-discipline
// card UI (5 hardcoded cards: SO/Str/Asb/Civ/Prv) with arbitrary user-named
// cards tagged with the 4-code discipline system (DEM/CIV/ASB/Other). Each
// card holds scope items, concrete cutting lines, and waste summary lines.
//
// Authoritative discipline ownership: the card's `discipline` field is the
// canonical answer for "what discipline is this work?". After PR A2 lands,
// PR A2.5 migrates queries to read `card.discipline` and drops
// `ScopeOfWorksItem.discipline`. Until then, this PR keeps both in sync via
// the data migration and leaves item.discipline as the read source for all
// services.
model ScopeCard {
  id                    String   @id @default(uuid())
  tenderId              String   @map("tender_id")
  tender                Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  name                  String
  discipline            String
  // PR B1 â€" stable integer identifier per (tenderId, discipline). Never
  // reused (deleted card numbers stay burned). Combined with discipline
  // to form the card "code" (DEM1, DEM2, CIV1...). Items inside use
  // dotted codes (DEM1.1, DEM1.2...) derived from this.
  cardNumber            Int      @map("card_number")
  // PR B1.6 â€" per-card Plant column count. Plant 1 always visible
  // (never removable); Plant 2+ added via the "+" button on the Plant N
  // header. Each scope item's plantItems JSON array uses columnIndex
  // matching this column count (dense with explicit columnIndex).
  plantColumnCount      Int      @default(1) @map("plant_column_count")
  // PR B1.7 â€" shared notes blocks at the bottom of the Cutting and Waste
  // subtables. Replace the previous per-row notes column / NotesRow.
  cuttingNotes          String?  @map("cutting_notes")
  wasteNotes            String?  @map("waste_notes")
  // PR B2 â€" per-card markup override. null = inherit TenderEstimate.markup;
  // any non-null value overrides for this card only. Percent expressed as
  // a decimal (e.g. 30.00 means 30%). Reset via Ã— button on the input or
  // bulk POST /scope/markup/reset-all.
  markupOverride        Decimal? @map("markup_override") @db.Decimal(5, 2)
  // Per-section markup overrides. null = inherit TenderEstimate.markup;
  // any non-null value overrides that section only. Independent cost
  // streams: waste and cutting each carry their own markup applied to
  // their own base, distinct from the scope-card markupOverride above.
  wasteMarkupOverride   Decimal? @map("waste_markup_override") @db.Decimal(5, 2)
  cuttingMarkupOverride Decimal? @map("cutting_markup_override") @db.Decimal(5, 2)
  peakCrewOverride      Int?     @map("peak_crew_override")
  labourDaysOverride    Decimal? @map("labour_days_override") @db.Decimal(10, 2)
  plantSummaryOverride  String?  @map("plant_summary_override")
  durationOverride      Decimal? @map("duration_override") @db.Decimal(10, 2)
  sortOrder             Int      @default(0) @map("sort_order")
  createdById           String   @map("created_by_id")
  createdBy             User     @relation("ScopeCardCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  scopeItems   ScopeOfWorksItem[]
  wasteItems   ScopeWasteItem[]
  cuttingItems CuttingSheetItem[]

  @@unique([tenderId, discipline, cardNumber])
  @@index([tenderId, sortOrder])
  @@map("scope_cards")
}

// â"€â"€ Scope of Works (PR #44) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Interactive QS sheet â€" sits between the tender documents and the
// estimate. Rows are discipline-typed and carry row-type-specific fields
// (demolition sqm, cutting lm, asbestos ACM, excavation m3, waste tonnes,
// plant days). AI-drafted rows start as status="draft", aiProposed=true;
// confirming a row triggers auto-creation of the matching EstimateItem.
model ScopeOfWorksItem {
  id           String     @id @default(uuid())
  tenderId     String     @map("tender_id")
  tender       Tender     @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  // PR A2 â€" parent card. Nullable retained for ON DELETE SET NULL semantics
  // (deleting a card preserves child rows). PR A2.5 dropped the legacy
  // `discipline` String column from this model; card.discipline is now
  // the authoritative source.
  cardId       String?    @map("card_id")
  card         ScopeCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  wbsCode      String     @map("wbs_code")
  itemNumber   Int        @map("item_number")
  rowType      String     @map("row_type")
  description  String
  status       String     @default("confirmed")
  aiProposed   Boolean    @default(false) @map("ai_proposed")
  aiConfidence String?    @map("ai_confidence")
  aiSourceRef  String?    @map("ai_source_ref")
  sortOrder    Int        @default(0) @map("sort_order")
  notes        String?

  // General (all rows)
  men   Decimal? @db.Decimal(8, 2)
  days  Decimal? @db.Decimal(8, 2)
  shift String?

  // PR B1.6 â€" canonical items table columns. `wasteGroup` (below) +
  // `wasteItem` form the group/item dropdown pair. `wasteIncluded` flags
  // whether this row contributes to the auto-generated waste summary.
  //
  // @deprecated PR B4a â€" `unit` + `value` superseded by the L/H/D + sqm/
  // m3/density/tonnes + chargeBy dimension fields below. Retained for
  // backward compat with rows written by B1.6â€"B3; no longer read or
  // written by new code. Cleanup PR drops the columns.
  unit          String?  @map("unit")
  value         Decimal? @map("value") @db.Decimal(12, 3)
  wasteItem     String?  @map("waste_item")
  wasteIncluded Boolean  @default(false) @map("waste_included")

  // PR B4a â€" dimension/quantification fields. Raw inputs (length, height,
  // depth, density) drive auto-derivation of sqm/m3/tonnes; any derived
  // value can be overridden by the user typing directly. `chargeBy` is
  // the user's preferred billing unit ("t" | "mÂ³") for the waste
  // aggregator; null = fall back to the facility's rate.unit.
  // `cuttingIncluded` mirrors `wasteIncluded` for the cutting subtable
  // (aggregator wired in B4b).
  length          Decimal? @db.Decimal(10, 3)
  height          Decimal? @db.Decimal(10, 3)
  depth           Decimal? @db.Decimal(10, 3)
  // PR B4a.6 â€" widened from Decimal(5,3) to Decimal(8,3) so users can
  // enter kg/mÂ³ values (e.g. concrete ~2400) without a numeric overflow
  // crash. Existing rows are safe (widening only; no data loss).
  density         Decimal? @db.Decimal(8, 3)
  tonnes          Decimal? @db.Decimal(10, 2)
  chargeBy        String?  @map("charge_by")
  cuttingIncluded Boolean  @default(false) @map("cutting_included")

  // PR B4a â€" sqm + m3 promoted from demolition-bucket to canonical
  // all-discipline dimension fields. Derived from lengthÃ—height /
  // sqmÃ—depth or supplied directly as an override.
  sqm          Decimal? @db.Decimal(10, 2)
  m3           Decimal? @db.Decimal(10, 2)
  materialType String?  @map("material_type")

  // Cutting
  cuttingEquipment   String?  @map("cutting_equipment")
  elevation          String?
  depthMm            Int?     @map("depth_mm")
  lm                 Decimal? @db.Decimal(10, 2)
  coreHoleDiameterMm Int?     @map("core_hole_diameter_mm")
  coreHoleQty        Decimal? @map("core_hole_qty") @db.Decimal(10, 2)

  // Asbestos
  acmType           String?  @map("acm_type")
  acmMaterial       String?  @map("acm_material")
  enclosureRequired Boolean? @map("enclosure_required")
  airMonitoring     Boolean? @map("air_monitoring")

  // Excavation / civil
  excavationDepthM   Decimal? @map("excavation_depth_m") @db.Decimal(8, 2)
  excavationMaterial String?  @map("excavation_material")
  machineSize        String?  @map("machine_size")

  // Waste / disposal
  wasteGroup    String?  @map("waste_group")
  wasteType     String?  @map("waste_type")
  wasteFacility String?  @map("waste_facility")
  wasteTonnes   Decimal? @map("waste_tonnes") @db.Decimal(10, 3)
  wasteLoads    Int?     @map("waste_loads")
  // @deprecated PR B4a â€" legacy demolition-bucket field. Superseded by
  // the all-discipline `m3` on ScopeOfWorksItem above. Retained for
  // backward compat; no longer read or written by new code.
  wasteM3       Decimal? @map("waste_m3") @db.Decimal(10, 2)

  // Redesign additions â€" generic measurement + material + plant FK.
  // The legacy sqm/m3/materialType/assetId columns are kept so old rows
  // render unchanged; new UI writes to these.
  measurementQty  Decimal? @map("measurement_qty") @db.Decimal(12, 3)
  measurementUnit String?  @map("measurement_unit")
  material        String?
  plantAssetId    String?  @map("plant_asset_id")
  plantAsset      Asset?   @relation("ScopeItemPlant", fields: [plantAssetId], references: [id], onDelete: SetNull)

  // Scope redesign v2 (PR #71) â€" multi-plant and multi-measurement rows.
  // JSON so we can append/remove without a separate table per row.
  //   plantItems:   [{ plantRateId?, description, qty, days, unit }]
  //   measurements: [{ qty, unit }]
  plantItems   Json? @map("plant_items")
  measurements Json?

  // PR feat/scope-multi-material — additional material rows on this
  // item. Row 1 remains stored on the flat materialType + length/height/
  // depth/density/sqm/m3/tonnes columns above; rows 2..N live here as
  // JSON so we can append/remove without a per-material table. Each
  // element: { material, length, height, depth, density, sqm, m3, tonnes }
  // — same shape and units as the flat row-1 fields. The item's total
  // tonnes/m3 is the SUM across row 1 + every element in this array.
  materials Json?

  // Provisional sum amount (discipline=Prv only). Final price = this value,
  // no markup applied. Ignored for non-Prv rows.
  provisionalAmount Decimal? @map("provisional_amount") @db.Decimal(12, 2)

  // Plant days
  excavatorDays  Decimal? @map("excavator_days") @db.Decimal(8, 2)
  bobcatDays     Decimal? @map("bobcat_days") @db.Decimal(8, 2)
  ewpDays        Decimal? @map("ewp_days") @db.Decimal(8, 2)
  hookTruckDays  Decimal? @map("hook_truck_days") @db.Decimal(8, 2)
  semiTipperDays Decimal? @map("semi_tipper_days") @db.Decimal(8, 2)
  assetId        String?  @map("asset_id")

  estimateItemId String? @map("estimate_item_id")
  createdById    String  @map("created_by_id")
  createdBy      User    @relation("ScopeOfWorksCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, itemNumber])
  @@index([tenderId, status])
  @@index([cardId])
  @@map("scope_of_works_items")
}

// Scope redesign v2 (PR #71). Waste rows move off the scope item row and
// into their own table so we can have multiple waste streams per WBS, each
// with its own facility / rate / truck-day calc. Legacy wasteTonnes /
// wasteLoads / wasteType / wasteFacility columns on ScopeOfWorksItem are
// retained for backward compat but no longer written by new code.
model ScopeWasteItem {
  id            String    @id @default(cuid())
  tenderId      String    @map("tender_id")
  tender        Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  // PR A2 â€" parent card. PR B-followup â€" promoted from nullable to
  // required. Per-card subtable became canonical in B3; zero orphan
  // rows existed at promotion time. onDelete changed from SetNull
  // (would violate NOT NULL) to Cascade â€" deleting a scope card
  // removes its waste rows.
  cardId        String    @map("card_id")
  card          ScopeCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  discipline    String
  wbsRef        String?   @map("wbs_ref")
  description   String
  wasteGroup    String?   @map("waste_group")
  wasteType     String?   @map("waste_type")
  wasteFacility String?   @map("waste_facility")
  // PR B4a â€" this column carried the aggregated waste quantity in
  // tonnes; PR B4a made it billable against either tonnes or mÂ³
  // depending on the facility's rate unit. The name became a lie once
  // it no longer meant "tonnes" universally, so the Prisma field is
  // now `qty` (chore/schema-hygiene-waste). The `waste_tonnes` DB
  // column was renamed to `qty` in the same PR â€" see migration
  // `20260701_chore_schema_hygiene_waste_rename_qty`.
  qty           Decimal?  @db.Decimal(10, 3)
  // PR B4a â€" mÂ³ companion to `qty` (previously wasteTonnes). Aggregator
  // writes both; facility's rate.unit decides which side the line
  // total bills against.
  m3            Decimal?  @db.Decimal(10, 2)
  wasteLoads    Int?      @map("waste_loads")
  // PR B3 â€" unit drives the facility filter on the summary subtable.
  // PR B4a â€" facility filter on the subtable no longer narrows by
  // unit; this column now carries the facility's rate unit forward
  // for display (read-only badge on the row).
  unit          String?
  // PR B3 â€" true when this row was created by "Sum from above" and
  // can be replaced on regeneration. Manual rows (default false) are
  // preserved across regenerations.
  autoSummed    Boolean   @default(false) @map("auto_summed")
  truckDays     Decimal?  @map("truck_days") @db.Decimal(5, 1)
  ratePerTonne  Decimal?  @map("rate_per_tonne") @db.Decimal(10, 2)
  ratePerLoad   Decimal?  @map("rate_per_load") @db.Decimal(10, 2)
  lineTotal     Decimal?  @map("line_total") @db.Decimal(12, 2)
  notes         String?
  sortOrder     Int       @default(0) @map("sort_order")
  createdById   String    @map("created_by_id")
  createdBy     User      @relation("ScopeWasteItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tenderId, discipline])
  @@index([cardId])
  @@map("scope_waste_items")
}

// Client-facing scope table on a ClientQuote â€" editable independently of
// the shared ScopeOfWorksItem source so different clients can see different
// levels of detail, different labels, different descriptions, or have items
// hidden entirely on a per-quote basis.
model QuoteScopeItem {
  id              String      @id @default(cuid())
  quoteId         String      @map("quote_id")
  quote           ClientQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sourceItemId    String?     @map("source_item_id")
  sourceItemType  String?     @map("source_item_type")
  label           String?
  description     String
  qty             String?
  unit            String?
  notes           String?
  quoteDiscipline String?     @map("quote_discipline")
  isVisible       Boolean     @default(true) @map("is_visible")
  sortOrder       Int         @default(0) @map("sort_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([quoteId])
  @@map("quote_scope_items")
}

model ScopeOfWorksHeader {
  id                String    @id @default(uuid())
  tenderId          String    @unique @map("tender_id")
  tender            Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  siteAddress       String?   @map("site_address")
  siteContactName   String?   @map("site_contact_name")
  siteContactPhone  String?   @map("site_contact_phone")
  accessConstraints String?   @map("access_constraints")
  proposedStartDate DateTime? @map("proposed_start_date")
  durationWeeks     Int?      @map("duration_weeks")
  specialConditions String?   @map("special_conditions")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("scope_of_works_headers")
}

// â"€â"€ Estimate export audit trail (PR #45) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// One row per PDF / Excel export. Server-side recalc runs on every export;
// nothing about the stored lines changes, we just keep a log of who
// generated what and when so the audit view can surface it.
model EstimateExport {
  id          String   @id @default(cuid())
  tenderId    String   @map("tender_id")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  type        String
  generatedAt DateTime @default(now()) @map("generated_at")
  generatedBy String   @map("generated_by")
  user        User     @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
  filePath    String?  @map("file_path")
  version     Int      @default(1)

  @@index([tenderId])
  @@map("estimate_exports")
}

// â"€â"€ Global Lists â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// User-manageable reference data (materials, measurement units, row types,
// etc.) plus dynamic lists that proxy to other modules (assets, workers).
// Items are archived, never hard-deleted â€" the `value` string is stored
// verbatim on the consuming record, so archived items still render on
// existing rows but drop out of dropdowns for new entries.
enum GlobalListType {
  STATIC
  DYNAMIC
}

model GlobalList {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  description  String?
  type         GlobalListType
  sourceModule String?          @map("source_module")
  isSystem     Boolean          @default(false) @map("is_system")
  createdById  String           @map("created_by_id")
  createdBy    User             @relation("GlobalListCreatedBy", fields: [createdById], references: [id])
  items        GlobalListItem[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("global_lists")
}

model GlobalListItem {
  id             String          @id @default(cuid())
  listId         String          @map("list_id")
  list           GlobalList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  value          String
  label          String
  metadata       Json?
  sortOrder      Int             @default(0) @map("sort_order")
  isArchived     Boolean         @default(false) @map("is_archived")
  createdById    String          @map("created_by_id")
  createdBy      User            @relation("GlobalListItemCreatedBy", fields: [createdById], references: [id])
  tenderPackages TenderPackage[] @relation("TenderPackageDiscipline")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([listId, value])
  @@index([listId, isArchived])
  @@map("global_list_items")
}

// â"€â"€ Tender Clarification Notes â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Simple sent/received communication log for a tender â€" the existing
// TenderClarification model is a different shape (Q&A with status/dueDate)
// used by the follow-up queue, so this is a parallel model for the
// Overview-tab clarifications log.
model TenderClarificationNote {
  id          String   @id @default(cuid())
  tenderId    String   @map("tender_id")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  direction   String
  // PR #72 â€" note type (call | email | meeting | note | response). RFI
  // remains a separate model (TenderClarification). Existing rows default
  // to "note" via the column default below.
  noteType    String   @default("note") @map("note_type")
  text        String
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TenderClarificationNoteAuthor", fields: [createdById], references: [id])
  // Â§5A.3 â€" optional client link so the Activity sidebar can filter
  // entries to a single client. Nullable for backward compatibility with
  // pre-existing rows.
  clientId    String?  @map("client_id")
  client      Client?  @relation("ClientTenderClarificationNotes", fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenderId, occurredAt])
  @@index([clientId])
  @@map("tender_clarification_notes")
}

// â"€â"€ Scope redesign â€" view config + cutting sheet â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// ScopeViewConfig persists which optional columns the user has enabled
// for a given (tender Ã— discipline) combination. The server owns the set
// of available columns per row type; this model only remembers the
// user's current selection so the UI can restore it after reload.
model ScopeViewConfig {
  id         String   @id @default(cuid())
  tenderId   String   @map("tender_id")
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  discipline String
  columns    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenderId, discipline])
  @@map("scope_view_configs")
}

// CuttingSheetItem is the concrete-cutting line-item store used by the
// Cutting Sheet tab of the Scope of Works redesign. It is tender-scoped
// (not estimate-item-scoped like the legacy EstimateCuttingLine) so it
// can be edited independently of estimate lines. Rate lookups and
// lineTotal calculations are performed server-side at write time.
model CuttingSheetItem {
  id           String            @id @default(cuid())
  tenderId     String            @map("tender_id")
  tender       Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  // PR A2 â€" parent card. PR B-followup â€" promoted from nullable to
  // required. Per-card subtable became canonical in B4b; the
  // transition window is closed. createCuttingItem now rejects
  // missing cardId at the service layer; the migration deleted the
  // 2 known pre-B4b orphan rows on T260512-BRIS-Rev1 before applying the
  // NOT NULL constraint. onDelete behaviour changed from SetNull
  // (which would now violate the NOT NULL constraint) to Cascade â€"
  // deleting a scope card removes its cutting rows.
  cardId       String            @map("card_id")
  card         ScopeCard         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  wbsRef       String            @map("wbs_ref")
  description  String?
  itemType     String            @map("item_type") // saw-cut | core-hole
  equipment    String?
  elevation    String? // Floor | Wall | Inverted
  material     String?
  depthMm      Int?              @map("depth_mm")
  diameterMm   Int?              @map("diameter_mm")
  quantityLm   Decimal?          @map("quantity_lm") @db.Decimal(10, 2)
  quantityEach Int?              @map("quantity_each")
  ratePerM     Decimal?          @map("rate_per_m") @db.Decimal(10, 4)
  ratePerHole  Decimal?          @map("rate_per_hole") @db.Decimal(10, 4)
  lineTotal    Decimal?          @map("line_total") @db.Decimal(12, 2)
  shift        String?
  shiftLoading Decimal?          @map("shift_loading") @db.Decimal(10, 2)
  method       String? // High-Freq | Low-emission | Fuel | N/A â€" applied as Ã—1.25 for High-Freq / Low-emission
  // Other-rate line items reference the CuttingOtherRate row so the rate
  // stays live â€" admin edits propagate to all tenders on next load.
  otherRateId  String?           @map("other_rate_id")
  otherRate    CuttingOtherRate? @relation(fields: [otherRateId], references: [id], onDelete: SetNull)
  notes        String?
  sortOrder    Int               @default(0) @map("sort_order")
  // PR B4b â€" marks rows created by the per-card "Copy from above"
  // aggregator. Replace semantics: re-running Copy from above deletes
  // autoCopied=true saw-cut rows on the card before regenerating, so
  // manual rows (autoCopied=false) and all core-hole/other-rate rows
  // survive. Mirrors ScopeWasteItem.autoSummed from B3.
  autoCopied   Boolean           @default(false) @map("auto_copied")
  createdById  String            @map("created_by_id")
  createdBy    User              @relation("CuttingSheetItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([tenderId, itemType, sortOrder])
  @@index([cardId])
  @@map("cutting_sheet_items")
}

// â"€â"€ Cutting â€" other rates â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Admin-managed flat-rate catalogue (establishment fees, wet-vac hire,
// stand-down time etc). Line items on the cutting sheet reference these
// rows so a rate change propagates to all tenders on next load.
model CuttingOtherRate {
  id           String             @id @default(cuid())
  description  String
  unit         String
  rate         Decimal            @db.Decimal(10, 2)
  isActive     Boolean            @default(true) @map("is_active")
  sortOrder    Int                @default(0) @map("sort_order")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  cuttingItems CuttingSheetItem[]

  @@index([isActive, sortOrder])
  @@map("cutting_other_rates")
}

// â"€â"€ Quote tab â€" T&C, Assumptions, Exclusions â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Per-tender editable copies. T&Cs seed from tc-text.const.ts on first read.
// Assumptions/exclusions pre-populate from IS standards on first list load
// (handled in the service) if the tender has none yet.
model TenderTandC {
  id        String   @id @default(cuid())
  tenderId  String   @unique @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  clauses   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tender_tandc")
}

model TenderAssumption {
  id        String   @id @default(cuid())
  tenderId  String   @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, sortOrder])
  @@map("tender_assumptions")
}

model TenderExclusion {
  id        String   @id @default(cuid())
  tenderId  String   @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, sortOrder])
  @@map("tender_exclusions")
}

// â"€â"€ Admin Settings â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// One row per notification trigger. isEnabled=false means "system-wide off"
// â€" even if an individual user opts in via their /account page they still
// won't receive it. Recipients are a union of role-based (roleNames) and
// user-id-based (recipientUserIds) addressees.
model NotificationTriggerConfig {
  id               String   @id @default(cuid())
  trigger          String   @unique
  label            String
  description      String
  isEnabled        Boolean  @default(false) @map("is_enabled")
  deliveryMethod   String   @default("both") @map("delivery_method")
  recipientRoles   String[] @map("recipient_roles")
  recipientUserIds String[] @map("recipient_user_ids")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("notification_trigger_configs")
}

// Singleton row (id="singleton") holding the active email provider + sender
// identity. Provider credentials themselves continue to live in env vars
// (SHAREPOINT_* doubles as Graph Mail credentials in practice), so this
// model only stores the mutable presentation/selection details.
model EmailProviderConfig {
  id            String   @id @default("singleton")
  provider      String   @default("outlook")
  senderAddress String   @default("marco@initialservices.net") @map("sender_address")
  senderName    String   @default("Initial Services") @map("sender_name")
  isConfigured  Boolean  @default(false) @map("is_configured")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id")
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("email_provider_config")
}

// Waste transport cost engine R3 T-0 (2026-07-15). Singleton pattern of
// EmailProviderConfig — one row keyed "singleton". Holds tenant-wide
// operations values that are not per-asset and not per-rate-table:
//   fuelPricePerLitre    — most recent fuel price (litre). T-2 will refresh
//                          it from an external feed; T-0 lets Marco set it
//                          manually via the Operations tab.
//   travelRatePerKm      — interim flat travel rate used until T-1 wires
//                          fuel × consumption × distance into the SoW line.
// All fields nullable → additive; nothing downstream currently reads them.
model OperationsSettings {
  id                 String    @id @default("singleton")
  fuelPricePerLitre  Decimal?  @map("fuel_price_per_litre") @db.Decimal(6, 3)
  fuelPriceSource    String?   @map("fuel_price_source")
  fuelPriceFetchedAt DateTime? @map("fuel_price_fetched_at")
  travelRatePerKm    Decimal?  @map("travel_rate_per_km") @db.Decimal(6, 2)
  // AU Security of Payment Act — statutory window (business days) in which
  // a respondent must issue a payment schedule after receiving a payment
  // claim. Varies by state (NSW 10, QLD 15, VIC 10, etc.); Marco sets the
  // value for the jurisdiction the tenant operates in. NULL = fall back to
  // SOPA_DEFAULT_RESPONSE_DAYS in the contracts service.
  sopaResponseDays   Int?      @map("sopa_response_days")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  updatedById        String?   @map("updated_by_id")
  updatedBy          User?     @relation("OperationsSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("operations_settings")
}

// â"€â"€ Contracts module â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// One Contract per Project. Variations and ProgressClaim roll up into the
// Contract; numbering is globally sequential (IS-C###, IS-V###, IS-PC###)
// via ContractNumberSequence row-lock, matching the IS-P### pattern for
// projects.
enum ContractStatus {
  ACTIVE
  PRACTICAL_COMPLETION
  DEFECTS
  CLOSED
}

enum VariationStatus {
  RECEIVED
  PRICED
  SUBMITTED
  APPROVED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
}

model Contract {
  id                    String                @id @default(cuid())
  projectId             String                @unique @map("project_id")
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractNumber        String                @unique @map("contract_number")
  contractValue         Decimal               @map("contract_value") @db.Decimal(12, 2)
  retentionPct          Decimal               @default(0) @map("retention_pct") @db.Decimal(5, 2)
  retentionAmount       Decimal               @default(0) @map("retention_amount") @db.Decimal(12, 2)
  startDate             DateTime?             @map("start_date")
  endDate               DateTime?             @map("end_date")
  status                ContractStatus        @default(ACTIVE)
  notes                 String?
  createdById           String                @map("created_by_id")
  createdBy             User                  @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  // Effective-dated T&C version pinned at contract creation. Same rationale
  // as ClientQuote.issuedTermsDocumentId â€" the executed contract must
  // forever render the T&Cs that were in force when it was signed.
  issuedTermsDocumentId String?               @map("issued_terms_document_id")
  issuedTerms           CompanyLegalDocument? @relation("ContractIssuedTerms", fields: [issuedTermsDocumentId], references: [id], onDelete: SetNull)
  variations            Variation[]
  progressClaims        ProgressClaim[]
  billingMilestones     BillingMilestone[]
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@map("contracts")
}

model Variation {
  id              String          @id @default(cuid())
  contractId      String          @map("contract_id")
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  variationNumber String          @unique @map("variation_number")
  description     String
  status          VariationStatus @default(RECEIVED)
  requestedBy     String?         @map("requested_by")
  pricedAmount    Decimal?        @map("priced_amount") @db.Decimal(12, 2)
  approvedAmount  Decimal?        @map("approved_amount") @db.Decimal(12, 2)
  receivedDate    DateTime        @default(now()) @map("received_date")
  pricedDate      DateTime?       @map("priced_date")
  submittedDate   DateTime?       @map("submitted_date")
  approvedDate    DateTime?       @map("approved_date")
  notes           String?
  createdById     String          @map("created_by_id")
  createdBy       User            @relation("VariationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  claimLineItems  ClaimLineItem[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([contractId])
  @@map("variations")
}

model ProgressClaim {
  id             String          @id @default(cuid())
  contractId     String          @map("contract_id")
  contract       Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  claimNumber    String          @unique @map("claim_number")
  claimMonth     DateTime        @map("claim_month")
  submissionDate DateTime?       @map("submission_date")
  status         ClaimStatus     @default(DRAFT)
  totalClaimed   Decimal         @default(0) @map("total_claimed") @db.Decimal(12, 2)
  totalApproved  Decimal?        @map("total_approved") @db.Decimal(12, 2)
  totalPaid      Decimal?        @map("total_paid") @db.Decimal(12, 2)
  paidDate       DateTime?       @map("paid_date")
  retentionHeld  Decimal         @default(0) @map("retention_held") @db.Decimal(12, 2)
  notes          String?
  lineItems      ClaimLineItem[]
  paymentSchedule PaymentSchedule?
  billingMilestones BillingMilestone[]
  isProForma     Boolean         @default(false) @map("is_pro_forma")
  createdById    String          @map("created_by_id")
  createdBy      User            @relation("ProgressClaimCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([contractId, claimMonth])
  @@index([contractId, status])
  @@map("progress_claims")
}

// AU Security of Payment Act response ("payment schedule") to a
// ProgressClaim. Statutory: if the respondent fails to issue a schedule
// within the state-defined window, the FULL claimed amount becomes
// payable — that is the risk this record is designed to surface.
// dueBy is computed at record-creation time from the claim's submission
// date + OperationsSettings.sopaResponseDays (business days, adjusted to
// the preceding QLD work day) and STORED so later setting changes do not
// retro-mutate an already-issued statutory window.
enum PaymentScheduleStatus {
  PENDING
  ISSUED
  OVERDUE
}

model PaymentSchedule {
  id              String                @id @default(cuid())
  progressClaimId String                @unique @map("progress_claim_id")
  progressClaim   ProgressClaim         @relation(fields: [progressClaimId], references: [id], onDelete: Cascade)
  scheduledAmount Decimal               @map("scheduled_amount") @db.Decimal(12, 2)
  reasons         String?
  status          PaymentScheduleStatus @default(PENDING)
  dueBy           DateTime              @map("due_by")
  respondedAt     DateTime?             @map("responded_at")
  createdById     String                @map("created_by_id")
  createdBy       User                  @relation("PaymentScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@map("payment_schedules")
}

model ClaimLineItem {
  id                String        @id @default(cuid())
  claimId           String        @map("claim_id")
  claim             ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  discipline        String?
  description       String
  contractValue     Decimal       @map("contract_value") @db.Decimal(12, 2)
  previouslyClaimed Decimal       @default(0) @map("previously_claimed") @db.Decimal(12, 2)
  thisClaimPct      Decimal?      @map("this_claim_pct") @db.Decimal(5, 2)
  thisClaimAmount   Decimal       @default(0) @map("this_claim_amount") @db.Decimal(12, 2)
  variationId       String?       @map("variation_id")
  variation         Variation?    @relation(fields: [variationId], references: [id], onDelete: SetNull)
  sortOrder         Int           @default(0) @map("sort_order")

  @@index([claimId])
  @@map("claim_line_items")
}

// ── Billing milestones (D365-parity Tier 3) ─────────────────────────────
// Named milestones on a contract — a trigger (date / % complete / event)
// flips the milestone from PENDING → DUE; raising a claim from a DUE
// milestone links it here and marks it CLAIMED. Sits ALONGSIDE the
// existing monthly progress-claim flow (which stays the spine for AU
// construction); milestones are additive, not a replacement. Amount is
// either a fixed AUD figure OR a percentage of the contract value.
enum BillingMilestoneTrigger {
  DATE
  PERCENT_COMPLETE
  EVENT
}

enum BillingMilestoneAmountType {
  FIXED
  PERCENT_OF_CONTRACT
}

enum BillingMilestoneStatus {
  PENDING
  DUE
  CLAIMED
}

model BillingMilestone {
  id              String                      @id @default(cuid())
  contractId      String                      @map("contract_id")
  contract        Contract                    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  triggerType     BillingMilestoneTrigger     @map("trigger_type")
  // Only one of the trigger fields is meaningful — enforced in the service
  // to keep the model shape flat and easy to query.
  triggerDate     DateTime?                   @map("trigger_date")
  triggerPercent  Decimal?                    @map("trigger_percent") @db.Decimal(5, 2)
  triggerEvent    String?                     @map("trigger_event")
  amountType      BillingMilestoneAmountType  @map("amount_type")
  amount          Decimal?                    @db.Decimal(12, 2)
  amountPercent   Decimal?                    @map("amount_percent") @db.Decimal(5, 2)
  status          BillingMilestoneStatus      @default(PENDING)
  claimId         String?                     @map("claim_id")
  claim           ProgressClaim?              @relation(fields: [claimId], references: [id], onDelete: SetNull)
  sortOrder       Int                         @default(0) @map("sort_order")
  createdById     String                      @map("created_by_id")
  createdBy       User                        @relation("BillingMilestoneCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@index([contractId, status])
  @@map("billing_milestones")
}

model ContractNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("contract_number_sequences")
}

// LEGACY (PR B05) â€" per-year sequence behind the retired J-YYYY-NNN
// format. G5 numbers (J{YYMMDD}-{SLUG}-{NNN}) compute the per-client
// sequence from the jobs table on demand; this table is no longer read
// or incremented. Kept so nothing breaks on import â€" drop in a
// follow-up cleanup PR.
model JobNumberSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("job_number_sequences")
}

model VariationNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("variation_number_sequences")
}

model ClaimNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("claim_number_sequences")
}

// â"€â"€ Client quotes (per-client, per-revision) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// PR #62 split the PDF builder's data source away from the raw scope
// summary. A ClientQuote holds the estimator's curated cost lines (A, B,
// C...) that actually appear on the client PDF; the discipline totals
// from ScopeRedesignService.summary are hidden from the client entirely.
enum ClientQuoteStatus {
  DRAFT
  SENT
  SUPERSEDED
}

model ClientQuote {
  id                     String                 @id @default(cuid())
  tenderId               String                 @map("tender_id")
  tender                 Tender                 @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  clientId               String                 @map("client_id")
  client                 Client                 @relation(fields: [clientId], references: [id])
  // Traceability pointer back to the internal TenderEstimate this quote was
  // derived from. Nullable â€" pre-existing quotes and quotes authored without
  // a source estimate stay NULL. SetNull so deleting the estimate leaves the
  // quote intact but unlinked. No pricing behaviour is derived from this.
  sourceTenderEstimateId String?                @map("source_tender_estimate_id")
  sourceTenderEstimate   TenderEstimate?        @relation(fields: [sourceTenderEstimateId], references: [id], onDelete: SetNull)
  revision               Int                    @default(1)
  quoteRef               String                 @unique @map("quote_ref")
  status                 ClientQuoteStatus      @default(DRAFT)
  adjustmentPct          Decimal?               @map("adjustment_pct") @db.Decimal(5, 2)
  adjustmentAmt          Decimal?               @map("adjustment_amt") @db.Decimal(12, 2)
  adjustmentNote         String?                @map("adjustment_note")
  assumptionMode         String                 @default("free") @map("assumption_mode")
  showProvisional        Boolean                @default(false) @map("show_provisional")
  showCostOptions        Boolean                @default(false) @map("show_cost_options")
  showScopeTable         Boolean                @default(true) @map("show_scope_table")
  showAssumptions        Boolean                @default(true) @map("show_assumptions")
  showExclusions         Boolean                @default(true) @map("show_exclusions")
  showReferencedDrawings Boolean                @default(true) @map("show_referenced_drawings")
  sentAt                 DateTime?              @map("sent_at")
  sentById               String?                @map("sent_by_id")
  sentBy                 User?                  @relation("QuoteSentBy", fields: [sentById], references: [id])
  generatedPdfPath       String?                @map("generated_pdf_path")
  // Effective-dated T&C version pinned at issue time. NULL until the quote
  // is sent â€" at send-time we resolve the currently-active TERMS_AND_CONDITIONS
  // and stamp its id here. Editing T&Cs later creates a new version; this
  // FK still points at the old one, so the historical PDF renders the
  // legal terms actually agreed to. See ADR: legal-doc-versioning.
  issuedTermsDocumentId  String?                @map("issued_terms_document_id")
  issuedTerms            CompanyLegalDocument?  @relation("QuoteIssuedTerms", fields: [issuedTermsDocumentId], references: [id], onDelete: SetNull)
  createdById            String                 @map("created_by_id")
  createdBy              User                   @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  costLines              QuoteCostLine[]
  provisionalLines       QuoteProvisionalLine[]
  costOptions            QuoteCostOption[]
  assumptions            QuoteAssumption[]
  exclusions             QuoteExclusion[]
  emails                 QuoteEmail[]
  scopeItems             QuoteScopeItem[]
  detailLevel            String                 @default("simple") @map("detail_level")

  @@unique([tenderId, clientId, revision])
  @@index([tenderId])
  @@index([clientId])
  @@index([sourceTenderEstimateId])
  @@map("client_quotes")
}

model QuoteCostLine {
  id                     String            @id @default(cuid())
  quoteId                String            @map("quote_id")
  quote                  ClientQuote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  label                  String
  description            String
  displayDescription     String?           @map("display_description")
  price                  Decimal           @db.Decimal(12, 2)
  baseValue              Decimal           @default(0) @map("base_value") @db.Decimal(14, 2)
  overrideAmount         Decimal?          @map("override_amount") @db.Decimal(14, 2)
  sortOrder              Int               @default(0) @map("sort_order")
  isVisible              Boolean           @default(true) @map("is_visible")
  // Traceability pointer back to the internal estimate line this quote line
  // was derived from. Polymorphic because the source can be any Estimate*Line
  // variant (labour / plant / equip / waste / cutting), which have no shared
  // parent table to FK to â€" same shape used by AuditLog.entityType/entityId.
  // Both nullable; both set together or both NULL.
  sourceEstimateLineType String?           @map("source_estimate_line_type")
  sourceEstimateLineId   String?           @map("source_estimate_line_id")
  assumptions            QuoteAssumption[] @relation("CostLineAssumptions")

  @@index([quoteId])
  @@index([sourceEstimateLineType, sourceEstimateLineId])
  @@map("quote_cost_lines")
}

model QuoteProvisionalLine {
  id          String      @id @default(cuid())
  quoteId     String      @map("quote_id")
  quote       ClientQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  price       Decimal     @db.Decimal(12, 2)
  notes       String?
  sortOrder   Int         @default(0) @map("sort_order")

  @@index([quoteId])
  @@map("quote_provisional_lines")
}

model QuoteCostOption {
  id          String      @id @default(cuid())
  quoteId     String      @map("quote_id")
  quote       ClientQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  label       String
  description String
  price       Decimal     @db.Decimal(12, 2)
  notes       String?
  sortOrder   Int         @default(0) @map("sort_order")

  @@index([quoteId])
  @@map("quote_cost_options")
}

model QuoteAssumption {
  id         String         @id @default(cuid())
  quoteId    String         @map("quote_id")
  quote      ClientQuote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  costLineId String?        @map("cost_line_id")
  costLine   QuoteCostLine? @relation("CostLineAssumptions", fields: [costLineId], references: [id], onDelete: SetNull)
  text       String
  sortOrder  Int            @default(0) @map("sort_order")

  @@index([quoteId])
  @@index([costLineId])
  @@map("quote_assumptions")
}

model QuoteExclusion {
  id        String      @id @default(cuid())
  quoteId   String      @map("quote_id")
  quote     ClientQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int         @default(0) @map("sort_order")

  @@index([quoteId])
  @@map("quote_exclusions")
}

model QuoteEmail {
  id          String      @id @default(cuid())
  quoteId     String      @map("quote_id")
  quote       ClientQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sentTo      String[]    @map("sent_to")
  subject     String
  bodyPreview String?     @map("body_preview")
