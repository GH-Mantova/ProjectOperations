model EntityInsurance {
  id              String                 @id @default(cuid())
  insuranceType   String                 @map("insurance_type")
  insurerName     String?                @map("insurer_name")
  policyNumber    String?                @map("policy_number")
  coverageAmount  Decimal?               @map("coverage_amount") @db.Decimal(14, 2)
  expiryDate      DateTime?              @map("expiry_date")
  documentPath    String?                @map("document_path")
  notes           String?
  status          String                 @default("active")
  clientId        String?                @map("client_id")
  client          Client?                @relation("ClientInsurances", fields: [clientId], references: [id], onDelete: Cascade)
  subcontractorId String?                @map("subcontractor_id")
  subcontractor   SubcontractorSupplier? @relation("SubInsurances", fields: [subcontractorId], references: [id], onDelete: Cascade)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([expiryDate])
  @@index([clientId])
  @@index([subcontractorId])
  @@map("entity_insurances")
}

model CreditApplication {
  id              String                 @id @default(cuid())
  direction       String
  status          String                 @default("draft")
  creditLimit     Decimal?               @map("credit_limit") @db.Decimal(12, 2)
  paymentTerms    Int?                   @map("payment_terms")
  applicationDate DateTime?              @map("application_date")
  approvedDate    DateTime?              @map("approved_date")
  rejectedDate    DateTime?              @map("rejected_date")
  reviewedById    String?                @map("reviewed_by_id")
  reviewedBy      User?                  @relation("CreditAppReviewer", fields: [reviewedById], references: [id])
  notes           String?
  documentPath    String?                @map("document_path")
  accountNumber   String?                @map("account_number")
  clientId        String?                @map("client_id")
  client          Client?                @relation("ClientCreditApps", fields: [clientId], references: [id], onDelete: Cascade)
  subcontractorId String?                @map("subcontractor_id")
  subcontractor   SubcontractorSupplier? @relation("SubCreditApps", fields: [subcontractorId], references: [id], onDelete: Cascade)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  createdById     String                 @map("created_by_id")
  createdBy       User                   @relation("CreditAppCreator", fields: [createdById], references: [id])

  @@index([status])
  @@index([clientId])
  @@index([subcontractorId])
  @@map("credit_applications")
}

// Transactional ledger of charges / payments against a supplier's credit
// account. The headline limit (`creditLimit`) and approval flag
// (`creditApproved`) live on SubcontractorSupplier — this table records the
// movements that determine the *current balance* and *remaining credit*.
// Amounts are stored unsigned; `entryType` carries the sign (charge = owed
// to supplier, payment = paid).
model SupplierCreditEntry {
  id              String                @id @default(cuid())
  subcontractorId String                @map("subcontractor_id")
  subcontractor   SubcontractorSupplier @relation("SupplierCreditEntries", fields: [subcontractorId], references: [id], onDelete: Cascade)
  entryDate       DateTime              @map("entry_date")
  entryType       String                @map("entry_type") // "charge" | "payment"
  amount          Decimal               @db.Decimal(12, 2)
  reference       String?
  note            String?
  createdAt       DateTime              @default(now()) @map("created_at")
  createdById     String                @map("created_by_id")
  createdBy       User                  @relation("SupplierCreditEntryCreator", fields: [createdById], references: [id])

  @@index([subcontractorId])
  @@index([entryDate])
  @@map("supplier_credit_entries")
}

model SubcontractorDocument {
  id              String                @id @default(cuid())
  subcontractorId String                @map("subcontractor_id")
  subcontractor   SubcontractorSupplier @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  documentType    String                @map("document_type")
  name            String
  filePath        String?               @map("file_path")
  uploadedAt      DateTime              @default(now()) @map("uploaded_at")
  uploadedById    String                @map("uploaded_by_id")
  uploadedBy      User                  @relation("SubDocUploadedBy", fields: [uploadedById], references: [id])
  notes           String?

  @@index([subcontractorId])
  @@map("subcontractor_documents")
}

