// NOTE: SubcontractorContact was unified into the polymorphic Contact model in
// PR #75 â€" rows were copied into `contacts` then. The legacy
// `subcontractor_contacts` table was dropped in PR #78
// (migration 20260426_feat_drop_deprecated_tables).

model EntityLicence {
  id               String                 @id @default(cuid())
  licenceType      String                 @map("licence_type")
  licenceNumber    String?                @map("licence_number")
  issuingAuthority String?                @map("issuing_authority")
  issueDate        DateTime?              @map("issue_date")
  expiryDate       DateTime?              @map("expiry_date")
  documentPath     String?                @map("document_path")
  notes            String?
  status           String                 @default("active")
  clientId         String?                @map("client_id")
  client           Client?                @relation("ClientLicences", fields: [clientId], references: [id], onDelete: Cascade)
  subcontractorId  String?                @map("subcontractor_id")
  subcontractor    SubcontractorSupplier? @relation("SubLicences", fields: [subcontractorId], references: [id], onDelete: Cascade)
  // Company profile ownership â€" polymorphic reuse for OUR own licences
  // (demolition, asbestos, QBCC). Alerted through the same compliance cron
  // as subcontractors; never triggers auto-block (a company cannot block
  // itself). Exactly one of client/subcontractor/companyProfile is set.
  companyProfileId String?                @map("company_profile_id")
  companyProfile   CompanyProfile?        @relation("CompanyLicences", fields: [companyProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([expiryDate])
  @@index([clientId])
  @@index([subcontractorId])
  @@index([companyProfileId])
  @@map("entity_licences")
}

model EntityInsurance {
  id               String                 @id @default(cuid())
  insuranceType    String                 @map("insurance_type")
  insurerName      String?                @map("insurer_name")
  policyNumber     String?                @map("policy_number")
