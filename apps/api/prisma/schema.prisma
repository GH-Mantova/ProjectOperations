  @@index([clientId])
  @@map("sites")
}

// ERP gap C — geofenced clock-in/out (QuickBooks Time parity). Timesheet GPS
// capture already existed (clockOnLat/Lng, clockOffLat/Lng); this record adds
// the second half: a circular boundary attached to a Site so we can (a) flag
// clock events as in/out-of-geofence for audit, and (b) tell the field app
// which job's geofence the worker is currently standing in so it can auto-
// select the correct allocation. No continuous tracking — evaluation runs on
// clock-event submissions and on explicit on-demand lookups only.
model SiteGeofence {
  id             String      @id @default(cuid())
  siteId         String      @map("site_id")
  site           Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name           String
  centreLat      Decimal     @map("centre_lat") @db.Decimal(9, 6)
  centreLng      Decimal     @map("centre_lng") @db.Decimal(9, 6)
  radiusMetres   Int         @map("radius_metres")
  isActive       Boolean     @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  clockOnEvents  Timesheet[] @relation("TimesheetClockOnGeofence")
  clockOffEvents Timesheet[] @relation("TimesheetClockOffGeofence")

  @@index([siteId, isActive])
  @@map("site_geofences")
}

