// ─── Forms Engine (PR #611) — corrective-action / CAPA close-out ────────────
//
// A CorrectiveAction is raised when a form submission triggers a
// `create_corrective_action` on_submit action (e.g. a Fail answer on an
// inspection). It is linked back to the submission via FormTriggeredRecord
// (recordType = "corrective_action") and tracked through open →
// in_progress → closed. The optional submissionId foreign-key enables
// the submission detail page to list all actions the form raised.

model CorrectiveAction {
  id              String          @id @default(cuid())
  submissionId    String?         @map("submission_id")
  submission      FormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  sourceFieldKey  String?         @map("source_field_key")
  title           String
  description     String?
  assignedToId    String?         @map("assigned_to_id")
  assignedTo      User?           @relation("CorrectiveActionAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToRole  String?         @map("assigned_to_role")
  dueAt           DateTime?       @map("due_at")
  priority        String          @default("medium")
  status          String          @default("open")
  closedAt        DateTime?       @map("closed_at")
  closedById      String?         @map("closed_by_id")
  closedBy        User?           @relation("CorrectiveActionCloser", fields: [closedById], references: [id], onDelete: SetNull)
  closeOutNote    String?         @map("close_out_note")
  evidencePath    String?         @map("evidence_path")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([submissionId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueAt])
  @@map("corrective_actions")
}

