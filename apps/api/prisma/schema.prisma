  siteAddressState        String               @map("site_address_state")
  siteAddressPostcode     String               @map("site_address_postcode")
  requiredQualifications  String[]             @default([]) @map("required_qualifications")
  contractValue           Decimal              @default(0) @map("contract_value") @db.Decimal(12, 2)
  budget                  Decimal              @default(0) @db.Decimal(12, 2)
  actualCost              Decimal              @default(0) @map("actual_cost") @db.Decimal(12, 2)
  proposedStartDate       DateTime?            @map("proposed_start_date")
  actualStartDate         DateTime?            @map("actual_start_date")
  practicalCompletionDate DateTime?            @map("practical_completion_date")
  closedDate              DateTime?            @map("closed_date")
  projectManagerId        String?              @map("project_manager_id")
  projectManager          User?                @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  supervisorId            String?              @map("supervisor_id")
  supervisor              User?                @relation("ProjectSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  estimatorId             String?              @map("estimator_id")
  estimator               User?                @relation("ProjectEstimator", fields: [estimatorId], references: [id], onDelete: SetNull)
  whsOfficerId            String?              @map("whs_officer_id")
  whsOfficer              User?                @relation("ProjectWHS", fields: [whsOfficerId], references: [id], onDelete: SetNull)
  estimateSnapshot        Json                 @map("estimate_snapshot")
  createdById             String               @map("created_by_id")
  createdBy               User                 @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  scopeItems              ProjectScopeItem[]
  milestones              ProjectMilestone[]
  activityLog             ProjectActivityLog[]
  documents               TenderDocumentLink[]
  allocations             ProjectAllocation[]
  scheduleAllocations     ScheduleAllocation[]
  preStartChecklists      PreStartChecklist[]
  timesheets              Timesheet[]
  contract                Contract?
  safetyIncidents         SafetyIncident[]
  hazardObservations      HazardObservation[]
  ganttTasks              GanttTask[]
  dailyDiaries            DailyDiary[]
  plannedStartDate        DateTime?            @map("planned_start_date")
  plannedEndDate          DateTime?            @map("planned_end_date")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

