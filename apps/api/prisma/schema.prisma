  @@map("tender_client_notes")
}

model PlatformConfig {
  id                String   @id
  // Per-provider model overrides â€" live feature.
  // Read by PlatformConfigService.getModel / providerStatus, written
  // by setModel. Currently NULL across all providers in dev.
  // Decision pending in PHASE 6: keep, replace with per-user setting
  // on UserPersonaSettings, or drop entirely.
  anthropicModel    String?  @map("anthropic_model")
  geminiModel       String?  @map("gemini_model")
  groqModel         String?  @map("groq_model")
  openaiModel       String?  @map("openai_model")
  preferredProvider String?  @map("preferred_provider")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedById       String?  @map("updated_by_id")

  // Â§5A.1 PR 9 â€" BYOK encrypted company keys. AES-256-GCM via
  // KeyEncryptionService, BYOK_ENCRYPTION_KEY master, format
  // "<iv-base64>:<authTag-base64>:<ciphertext-base64>". validatedAt is set
  // by KeyValidationService on successful live test against the provider.
  anthropicKeyEncrypted   String?   @map("anthropic_key_encrypted")
  anthropicKeyValidatedAt DateTime? @map("anthropic_key_validated_at")
  openaiKeyEncrypted      String?   @map("openai_key_encrypted")
  openaiKeyValidatedAt    DateTime? @map("openai_key_validated_at")
  geminiKeyEncrypted      String?   @map("gemini_key_encrypted")
  geminiKeyValidatedAt    DateTime? @map("gemini_key_validated_at")
  groqKeyEncrypted        String?   @map("groq_key_encrypted")
  groqKeyValidatedAt      DateTime? @map("groq_key_validated_at")

  @@map("platform_config")
}

// Third-party integration API keys (e.g. Geoapify, fuelpricesqld). Moves
// manually-entered keys out of Azure App Service config and into the ERP so
// they can be rotated from the UI. Encrypted at rest with the same
// KeyEncryptionService (AES-256-GCM, BYOK_ENCRYPTION_KEY master) used by the
// AI provider keys. Presence of valueEncrypted = "configured".
// resolveIntegrationKey(slug) falls back to matching env var when the DB row
// has no value, so keys already set in Azure keep working during transition.
// This store is for THIRD-PARTY keys only — never for infra/managed-identity
// secrets or the BYOK master itself.
model IntegrationCredential {
  slug           String   @id
  label          String
  valueEncrypted String?  @map("value_encrypted")
  meta           Json?
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedById    String?  @map("updated_by_id")

  @@map("integration_credentials")
}

// UserAiProvider and UserAiPreference models were removed in Â§5A.1 PR 8
// (PR #132) â€" provider selection moved to persona settings. Tables dropped
// via migration 20260502_chore_remove_legacy_ai_provider_tables.

// â"€â"€ Projects module (PR #39) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Project records live alongside Job (delivery-side) and are produced by the
// tenderâ†'project conversion flow. IS-P### numbers are issued from a locked
// sequence row at conversion time.

enum ProjectStatus {
  MOBILISING
  ACTIVE
  PRACTICAL_COMPLETION
  DEFECTS
  CLOSED
}

enum ProjectActivityAction {
  PROJECT_CREATED
  STATUS_CHANGED
  TEAM_CHANGED
  CONTRACT_VALUE_CHANGED
  BUDGET_CHANGED
  DOCUMENT_ADDED
  DOCUMENT_REMOVED
  WORKER_ALLOCATED
  ASSET_ALLOCATED
  TIMESHEET_SUBMITTED
  TIMESHEET_REJECTED
  PRESTART_SUBMITTED
}

enum AllocationTargetType {
  WORKER
  ASSET
}

model ProjectNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("project_number_sequences")
}

model Project {
  id                      String               @id @default(cuid())
  projectNumber           String               @unique @map("project_number")
  jobNumber               String?              @unique @map("job_number")
  legacyJobId             String?              @unique @map("legacy_job_id")
  name                    String
  status                  ProjectStatus        @default(MOBILISING)
  sourceTenderId          String?              @unique @map("source_tender_id")
  sourceTender            Tender?              @relation(fields: [sourceTenderId], references: [id], onDelete: SetNull)
  sourceJobId             String?              @unique @map("source_job_id")
  sourceJob               Job?                 @relation("ProjectSourceJob", fields: [sourceJobId], references: [id], onDelete: SetNull)
  reverseSurvivorOf       Job?                 @relation("JobSurvivingProject")
  clientId                String               @map("client_id")
  client                  Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  siteId                  String               @map("site_id")
