model Tender {
  id                  String                    @id @default(cuid())
  tenderNumber        String                    @unique @map("tender_number")
  // G5 — canonical T{YYMMDD}-{SLUG}-Rev{N}: revision counter + slug frozen
  // at creation (nullable for rows older than the backfill migration).
  revisionNumber      Int                       @default(1) @map("revision_number")
  clientSlugSnapshot  String?                   @map("client_slug_snapshot")
  title               String
  description         String?
  estimatorUserId     String?                   @map("estimator_user_id")
  assignedEstimatorId String?                   @map("assigned_estimator_id")
  siteId              String?                   @map("site_id")
  status              String                    @default("DRAFT")
  dueDate             DateTime?                 @map("due_date")
  proposedStartDate   DateTime?                 @map("proposed_start_date")
  leadTimeDays        Int?                      @map("lead_time_days")
  probability         Int?
  estimatedValue      Decimal?                  @map("estimated_value") @db.Decimal(14, 2)
  notes               String?
  submittedAt         DateTime?                 @map("submitted_at")
  ratesSnapshotAt     DateTime?                 @map("rates_snapshot_at")
  tenderScoreCounted  Boolean                   @default(false) @map("tender_score_counted")
  wonAt               DateTime?                 @map("won_at")
  lostAt              DateTime?                 @map("lost_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  estimator           User?                     @relation("TenderEstimator", fields: [estimatorUserId], references: [id], onDelete: SetNull)
  assignedEstimator   User?                     @relation("TenderAssignedEstimator", fields: [assignedEstimatorId], references: [id], onDelete: SetNull)
  site                Site?                     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  tenderClients       TenderClient[]
  tenderNotes         TenderNote[]
  clarifications      TenderClarification[]
  pricingSnapshots    TenderPricingSnapshot[]
  followUps           TenderFollowUp[]
  outcomes            TenderOutcome[]
  tenderDocuments     TenderDocumentLink[]
  sourceJob           Job?
  jobConversion       JobConversion?
  estimate            TenderEstimate?
  clientNotes         TenderClientNote[]
  scopeRevisions      TenderScopeRevision[]
  scopeItems          ScopeOfWorksItem[]
  scopeHeader         ScopeOfWorksHeader?
  scopeCards          ScopeCard[]
  estimateExports     EstimateExport[]
  projects            Project[]
  clarificationNotes  TenderClarificationNote[]
  entries             TenderEntry[]
  cuttingSheetItems   CuttingSheetItem[]
  scopeViewConfigs    ScopeViewConfig[]
  tandC               TenderTandC?
  assumptions         TenderAssumption[]
  exclusions          TenderExclusion[]
  clientQuotes        ClientQuote[]
  packages            TenderPackage[]
  wasteItems          ScopeWasteItem[]
  safetyIncidents     SafetyIncident[]
  hazardObservations  HazardObservation[]
  correspondences     CorrespondenceThread[]    @relation("TenderCorrespondence")
  rateSet             TenderRateSet?

  @@index([status])
  @@index([estimatorUserId])
  @@index([assignedEstimatorId])
  @@index([siteId])
  @@map("tenders")
}

model TenderClient {
  id               String                @id @default(cuid())
  tenderId         String                @map("tender_id")
  clientId         String                @map("client_id")
  contactId        String?               @map("contact_id")
  isAwarded        Boolean               @default(false) @map("is_awarded")
  contractIssued   Boolean               @default(false) @map("contract_issued")
  contractIssuedAt DateTime?             @map("contract_issued_at")
  submissionDate   DateTime?             @map("submission_date")
  relationshipType String?               @map("relationship_type")
  notes            String?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  tender           Tender                @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  client           Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
