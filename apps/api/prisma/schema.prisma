  supervisor         User?                  @relation("JobSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  conversion         JobConversion?
  stages             JobStage[]
  activities         JobActivity[]
  shifts             Shift[]
  issues             JobIssue[]
  variations         JobVariation[]
