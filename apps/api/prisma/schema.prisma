model Job {
  id                 String                 @id @default(cuid())
  jobNumber          String                 @unique @map("job_number")
  // G5 — canonical J{YYMMDD}-{SLUG}-{NNN}: slug frozen at creation.
  clientSlugSnapshot String?                @map("client_slug_snapshot")
  name               String
  description        String?
  clientId           String                 @map("client_id")
  siteId             String?                @map("site_id")
  sourceTenderId     String?                @unique @map("source_tender_id")
  survivingProjectId String?                @unique @map("surviving_project_id")
  status             String                 @default("PLANNING")
  projectManagerId   String?                @map("project_manager_id")
  supervisorId       String?                @map("supervisor_id")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  client             Client                 @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site               Site?                  @relation(fields: [siteId], references: [id], onDelete: SetNull)
  sourceTender       Tender?                @relation(fields: [sourceTenderId], references: [id], onDelete: SetNull)
