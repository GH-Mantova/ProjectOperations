  updatedAt                     DateTime @updatedAt @map("updated_at")

  @@map("global_ai_settings")
}

// Â§5A.1 PR 10 â€" persona chat history. One Conversation = one continuous
// thread within a (user, personaSlug, subMode, contextKey) scope.
// contextKey is null for global sub-modes (pipeline/register) and the
// tender id for tender-detail/scope/estimate/quote/clarifications. The
// "active" conversation for a scope is the most recent by updatedAt;
// the user can branch with the New conversation button on the panel.
model Conversation {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  personaSlug String   @map("persona_slug")
  subMode     String   @map("sub_mode")
  contextKey  String?  @map("context_key")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, personaSlug, subMode, contextKey, updatedAt(sort: Desc)])
  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  // role: 'user' | 'assistant' | 'tool_call' | 'tool_result' (string for
  // forward compat â€" TS types narrow at the application boundary).
  role           String
  content        String
  model          String?
  providerSource String?  @map("provider_source")
  // Â§5A.1 PR 11 â€" structured payload for tool-related messages. Null for
  // plain text messages. For tool_call: { toolUseId, name, arguments }.
  // For tool_result: { toolUseId, proposals: [{...status, acceptedScopeItemId?...}] }.
  // Multi-turn loop also stores tool_use_id + tool name + result content
  // here so an assistant turn with tool_use blocks and a synthesised user
  // turn with tool_result blocks can be replayed accurately.
  metadata       Json?    @db.JsonB
  // Â§5A.1 multi-turn loop: USER messages are visible in the UI replay;
  // INTERNAL messages (assistant turns whose only purpose was emitting
  // tool_use blocks, plus synthesised user turns carrying tool_result
  // blocks) are kept for model context but hidden from UI replay so the
  // user only sees their own messages and the model's final
  // human-facing responses. Default USER preserves PR #136 + #137 row
  // semantics for any pre-existing rows.
  visibility     String   @default("USER")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

// â"€â"€â"€ Correspondence Hub (PR #215) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Email threads attached to records (clients, tenders, jobs). Mock-mode first;
// live Microsoft Graph adapter is a follow-up (requires Mail.Read scopes).

model CorrespondenceThread {
  id            String   @id @default(cuid())
  // Polymorphic owner: exactly one of clientId/tenderId/jobId is set.
  clientId      String?  @map("client_id")
  tenderId      String?  @map("tender_id")
  jobId         String?  @map("job_id")
  subject       String
  // Stable token embedded in outbound subjects (e.g. "[ref:abc123]") so
  // inbound replies can be matched back to the originating thread even when
  // the user's mail client strips/changes other headers.
  referenceKey  String   @unique @map("reference_key")
  // Convenience denorm: address(es) initially seeded with the thread for
  // recipient lookup when the thread is created against a non-user address.
  participants  String[] @default([])
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client   Client?                 @relation("ClientCorrespondence", fields: [clientId], references: [id], onDelete: Cascade)
  tender   Tender?                 @relation("TenderCorrespondence", fields: [tenderId], references: [id], onDelete: Cascade)
  job      Job?                    @relation("JobCorrespondence", fields: [jobId], references: [id], onDelete: Cascade)
  messages CorrespondenceMessage[]

  @@index([clientId])
  @@index([tenderId])
  @@index([jobId])
  @@index([lastMessageAt])
  @@map("correspondence_threads")
}

model CorrespondenceMessage {
  id          String    @id @default(cuid())
  threadId    String    @map("thread_id")
  direction   String // "outbound" | "inbound"
  fromAddress String    @map("from_address")
  toAddresses String[]  @map("to_addresses")
  ccAddresses String[]  @default([]) @map("cc_addresses")
  subject     String
  bodyText    String    @map("body_text")
  bodyHtml    String?   @map("body_html")
  // Provider message id (mock generates a stable cuid; live Graph supplies its
  // immutable id) â€" used for de-duplication when inbound mail is re-polled.
  externalId  String?   @unique @map("external_id")
  sentAt      DateTime? @map("sent_at")
  receivedAt  DateTime? @map("received_at")
  sentById    String?   @map("sent_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  thread CorrespondenceThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sentBy User?                @relation("CorrespondenceSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
  @@map("correspondence_messages")
}

// PR-216 â€" Calendar Sync (mock-mode). One row per (user, source item)
// recording the "external" event the adapter would have written to
// the user's calendar. Mock adapter stores everything here so the
// flow can be tested end-to-end without Microsoft Graph. The live
// Graph adapter (follow-up) would also keep this row as the local
// ledger / idempotency key, with externalEventId pointing at the
// Graph event id.
model CalendarSyncedEvent {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  // 'shift' for now. Extensible (e.g. 'site-visit', 'job-milestone')
  // without a schema change.
  sourceType      String   @map("source_type")
  sourceId        String   @map("source_id")
  // Mock-generated UUID stand-in for the Graph event id. Stable across
  // re-syncs so update semantics work.
  externalEventId String   @map("external_event_id")
  title           String
  startAt         DateTime @map("start_at")
  endAt           DateTime @map("end_at")
  location        String?
  // 'active' | 'cancelled'. Cancelled means the source item no longer
  // matches the sync filter (shift deleted, status moved away from
  // PLANNED/IN_PROGRESS, etc.) â€" the row is kept so the live adapter
  // can emit a Graph cancellation against externalEventId.
  status          String   @default("active")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation("CalendarSyncedEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
  @@index([userId, status])
  @@map("calendar_synced_events")
}

// PR-193b â€" In-app pilot feedback capture. Any logged-in user can submit a
// short note tied to the route they were on; admins read/triage the list.
// Intentionally light â€" no notifications, no attachments (follow-up).
model PilotFeedback {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation("PilotFeedbackUser", fields: [userId], references: [id], onDelete: Cascade)
  route     String
  // 'bug' | 'idea' | 'question' | 'other' â€" validated at the API boundary.
  category  String
  message   String
  // 'new' | 'triaged' | 'done'.
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([userId])
  @@map("pilot_feedback")
}

// PR-451 â€" Public holidays lookup. Region-aware, multi-year. Replaces hardcoded
// holiday maps in the Resource Allocator / Scheduler. Region defaults to "QLD";
// state-wide holidays use "QLD" and Brisbane-only days (e.g. Royal Queensland
// Show) use "BRISBANE" so callers can filter accordingly.
model PublicHoliday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  region    String   @default("QLD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date, region])
  @@index([region, date])
  @@map("public_holidays")
}

// PR-486 â€" Native inventory / stock layer (slice 1).
// Purpose-built for consumable stock (bolts, PPE, concrete, small parts) â€"
// intentionally SEPARATE from Asset/AssetCategory (which tracks unique,
// serialised, maintained plant). StockCategory does not overload
// AssetCategory: an "off-hire" from Assets is not the same domain as a
// "receive" against a stock item.
//
// Movements carry a signed Decimal quantity so the same shape handles
// receipts (+), issues (-), returns (+), and adjustments (either sign).
// The service enforces sign rules per StockMovementType and updates
// StockItem.quantityOnHand atomically via prisma.$transaction.
enum StockMovementType {
  RECEIVE
  ISSUE
  ADJUST
  RETURN
}

model StockCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stockItems StockItem[]

  @@map("stock_categories")
}

model StockItem {
  id             String   @id @default(cuid())
  name           String
  sku            String?
  categoryId     String?  @map("category_id")
  unit           String
  quantityOnHand Decimal  @default(0) @map("quantity_on_hand") @db.Decimal(14, 4)
  reorderLevel   Decimal? @map("reorder_level") @db.Decimal(14, 4)
  location       String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category        StockCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements       StockMovement[]
  stocktakeCounts StocktakeCount[]

  @@index([name])
  @@index([sku])
  @@index([categoryId])
  @@map("stock_items")
}

model StockMovement {
  id            String            @id @default(cuid())
  stockItemId   String            @map("stock_item_id")
  type          StockMovementType
  // Signed delta. RECEIVE/RETURN are stored positive; ISSUE is stored negative;
  // ADJUST is a signed delta (positive for count-up, negative for count-down)
  // so stocktake commits can encode variances in a single row.
  quantity      Decimal           @db.Decimal(14, 4)
  reason        String?
  refType       String?           @map("ref_type")
  refId         String?           @map("ref_id")
  movedByUserId String?           @map("moved_by_user_id")
  createdAt     DateTime          @default(now()) @map("created_at")

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([createdAt])
  @@map("stock_movements")
}

model StocktakeSession {
  id              String    @id @default(cuid())
  startedByUserId String?   @map("started_by_user_id")
  // Enforced at API boundary: "OPEN" | "COMMITTED" | "CANCELLED".
  status          String    @default("OPEN")
  notes           String?
  startedAt       DateTime  @default(now()) @map("started_at")
  committedAt     DateTime? @map("committed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  counts StocktakeCount[]

  @@index([status])
  @@map("stocktake_sessions")
}

model StocktakeCount {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  stockItemId String   @map("stock_item_id")
  systemQty   Decimal  @map("system_qty") @db.Decimal(14, 4)
  countedQty  Decimal  @map("counted_qty") @db.Decimal(14, 4)
  createdAt   DateTime @default(now()) @map("created_at")

  session   StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stockItem StockItem        @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stockItemId])
  @@index([sessionId])
  @@map("stocktake_counts")
}

// Authority seam (Phase 0.2). Configurable ceiling for approval / spend-limit
// decisions consulted by AuthorityService.check. Empty table = open ceiling:
// with no matching rule, the seam defaults to allowed and does not restrict
// any feature. Scope specificity (USER > ROLE > DEPARTMENT > GLOBAL) is
// resolved in code; the store is intentionally flat.
enum AuthorityScopeType {
  USER
  ROLE
  DEPARTMENT
  GLOBAL
}

model AuthorityRule {
  id               String             @id @default(cuid())
  scopeType        AuthorityScopeType @map("scope_type")
  scopeId          String?            @map("scope_id")
  action           String
  limitAmount      Decimal?           @map("limit_amount") @db.Decimal(12, 2)
  escalateToUserId String?            @map("escalate_to_user_id")
  enabled          Boolean            @default(true)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  createdById      String?            @map("created_by_id")
  updatedById      String?            @map("updated_by_id")

  @@unique([scopeType, scopeId, action])
  @@index([action])
  @@index([scopeType, scopeId])
  @@map("authority_rules")
}

// â"€â"€ Rates & Lists R0 (PR-487) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Additive-only flexible rate model + list-binding registry per
// docs/specs/rates-lists-tidyup-spec.md Â§3. The eight legacy rate tables
// (EstimateLabourRateâ€¦CuttingOtherRate) remain the pricing source of truth;
// nothing consumer-facing changes in R0. The resolver seam
// (RateResolverService) reads legacy tables by default. Later phases
// (R1â€¦Rn) route consumers through the seam and migrate one legacy table
// at a time.

enum RateTableCategory {
  INITIAL_SERVICES
  SUBCONTRACTOR
}

enum RateColumnDataType {
  TEXT
  NUMBER
  CURRENCY
  DATE
  BOOL
  LIST_REF
}

enum RateColumnRole {
  KEY
  VALUE
  INFO
}

enum ListBindingConsumerType {
  RATE_COLUMN
  FORM_FIELD
  MODULE_DROPDOWN
}

model RateTable {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  description       String?
  category          RateTableCategory
  subcontractorType String?                @map("subcontractor_type")
  supplierId        String?                @map("supplier_id")
  supplier          SubcontractorSupplier? @relation("RateTableSupplier", fields: [supplierId], references: [id])
  isSystem          Boolean                @default(false) @map("is_system")
  isReference       Boolean                @default(false) @map("is_reference")
  createdById       String?                @map("created_by_id")
  updatedById       String?                @map("updated_by_id")
  columns           RateColumn[]
  rows              RateRow[]
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  @@index([category])
  @@index([supplierId])
  @@map("rate_tables")
}

model RateColumn {
  id          String             @id @default(cuid())
  rateTableId String             @map("rate_table_id")
  rateTable   RateTable          @relation(fields: [rateTableId], references: [id], onDelete: Cascade)
  name        String
  dataType    RateColumnDataType @map("data_type")
  role        RateColumnRole
  unit        String?
  listSlug    String?            @map("list_slug")
  required    Boolean            @default(false)
  min         Decimal?           @db.Decimal(18, 6)
  max         Decimal?           @db.Decimal(18, 6)
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@unique([rateTableId, name])
  @@map("rate_columns")
}

model RateRow {
  id            String    @id @default(cuid())
  rateTableId   String    @map("rate_table_id")
  rateTable     RateTable @relation(fields: [rateTableId], references: [id], onDelete: Cascade)
  cells         Json
  isActive      Boolean   @default(true) @map("is_active")
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  sortOrder     Int       @default(0) @map("sort_order")
  createdById   String?   @map("created_by_id")
  updatedById   String?   @map("updated_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([rateTableId, isActive])
  @@map("rate_rows")
}

// Per-tender snapshot of the resolved rate set. Created when the user
// locks rates from the tender's Rates tab; deleted on unlock. Entries
// carry the original resolved value + an optional override the user
// edits without touching global rates or other tenders' snapshots.
model TenderRateSet {
  id          String            @id @default(cuid())
  tenderId    String            @unique @map("tender_id")
  lockedAt    DateTime          @default(now()) @map("locked_at")
  lockedById  String?           @map("locked_by_id")
  sourceLabel String?           @map("source_label")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  tender      Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  lockedBy    User?             @relation("TenderRateSetLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  entries     TenderRateEntry[]

  @@map("tender_rate_sets")
}

model TenderRateEntry {
  id              String        @id @default(cuid())
  tenderRateSetId String        @map("tender_rate_set_id")
  key             String
  rateTableId     String?       @map("rate_table_id")
  rateTableSlug   String?       @map("rate_table_slug")
  label           String
  unit            String?
  originalValue   Decimal       @map("original_value") @db.Decimal(18, 6)
  overrideValue   Decimal?      @map("override_value") @db.Decimal(18, 6)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  rateSet         TenderRateSet @relation(fields: [tenderRateSetId], references: [id], onDelete: Cascade)

  @@unique([tenderRateSetId, key])
  @@index([tenderRateSetId])
  @@map("tender_rate_entries")
}

model ListBinding {
  id           String                  @id @default(cuid())
  listId       String                  @map("list_id")
  consumerType ListBindingConsumerType @map("consumer_type")
  consumerRef  String                  @map("consumer_ref")
  label        String?
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  @@unique([listId, consumerType, consumerRef])
  @@index([listId])
  @@index([consumerType, consumerRef])
  @@map("list_bindings")
}

// â"€â"€ Procurement (PR-488 slice 1) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Request â†' approval â†' PO/subcontract spine per POL 1.2.14 / PRO 23.
// - Approval routing consults AuthorityService.check; empty ruleset = open
//   ceiling (matches the seam's default posture).
// - Sourcing gate thresholds live on ProcurementConfig (seed data), not
//   hardcoded in service code.
// - Out-of-allowance / job-budget escalation (Estimator â†' Director) is
//   DEFERRED until job budget is modelled. ProcurementService.submitRequest
//   carries a clearly-marked hook where that branch will slot in.
// - Supplier / stock-item / job FKs are stored as scalar columns (no
//   Prisma @relation back-refs on the existing models) to avoid modifying
//   SubcontractorSupplier, StockItem, or Job model shapes in this slice.

enum ProcurementRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ISSUED
  RECEIVED
  CANCELLED
}

enum ProcurementLineCategory {
  CONSUMABLE
  EQUIPMENT
  HIRE
  ASSET
  SUBCONTRACT
}

model ProcurementRequest {
  id                 String                   @id @default(cuid())
  reference          String                   @unique
  originUserId       String                   @map("origin_user_id")
  originDepartment   String?                  @map("origin_department")
  jobId              String?                  @map("job_id")
  status             ProcurementRequestStatus @default(DRAFT)
  supplierId         String?                  @map("supplier_id")
  approverUserId     String?                  @map("approver_user_id")
  requiresEscalation Boolean                  @default(false) @map("requires_escalation")
  authorityRuleId    String?                  @map("authority_rule_id")
  quoteEvidenceRef   String?                  @map("quote_evidence_ref")
  notes              String?
  submittedAt        DateTime?                @map("submitted_at")
  approvedAt         DateTime?                @map("approved_at")
  issuedAt           DateTime?                @map("issued_at")
  receivedAt         DateTime?                @map("received_at")
  cancelledAt        DateTime?                @map("cancelled_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  lines          ProcurementLine[]
  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@index([originUserId])
  @@index([supplierId])
  @@index([jobId])
  @@map("procurement_requests")
}

model ProcurementLine {
  id          String                  @id @default(cuid())
  requestId   String                  @map("request_id")
  description String
  category    ProcurementLineCategory
  stockItemId String?                 @map("stock_item_id")
  quantity    Decimal                 @db.Decimal(14, 4)
  unit        String
  unitPrice   Decimal?                @map("unit_price") @db.Decimal(14, 2)
  lineTotal   Decimal?                @map("line_total") @db.Decimal(14, 2)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  request ProcurementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([stockItemId])
  @@map("procurement_lines")
}

model PurchaseOrder {
  id                 String    @id @default(cuid())
  requestId          String    @map("request_id")
  poNumber           String    @unique @map("po_number")
  issuedToSupplierId String    @map("issued_to_supplier_id")
  issuedByUserId     String    @map("issued_by_user_id")
  issuedAt           DateTime  @default(now()) @map("issued_at")
  documentRef        String?   @map("document_ref")
  emailSentAt        DateTime? @map("email_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  request        ProcurementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendorInvoices VendorInvoice[]
  reconcileAudit PoReconcileAudit?

  @@index([requestId])
  @@index([issuedToSupplierId])
  @@map("purchase_orders")
}

// -- Three-way match (PR-629 slice 3) ----------------------------------------
// VendorInvoice: a supplier's invoice against a PurchaseOrder.
// Three-way match compares PO lines (ordered) vs receipt (received on the
// parent ProcurementRequest) vs invoice lines (billed) and flags variances
// outside the configurable tolerance bands. Matched invoices become
// READY_TO_PAY; variances above tolerance are held (HELD) pending approval via
// the AuthorityService seam. PoReconcileAudit captures the final close action
// for project-close audit.

enum InvoiceMatchStatus {
  PENDING    // posted but match not yet run
  MATCHED    // all lines within tolerance → ready to pay
  HELD       // variance above tolerance → requires approval
  APPROVED   // variance approved (authority seam) → ready to pay
  REJECTED   // invoice rejected after review
}

// Vendor invoice posted against a PurchaseOrder.
model VendorInvoice {
  id                String             @id @default(cuid())
  purchaseOrderId   String             @map("purchase_order_id")
  invoiceNumber     String             @map("invoice_number")
  supplierId        String             @map("supplier_id")
  invoiceDate       DateTime           @map("invoice_date") @db.Date
  dueDate           DateTime?          @map("due_date") @db.Date
  currencyCode      String             @default("AUD") @map("currency_code")
  // Total as stated on the supplier invoice (before our match verdict).
  invoicedTotal     Decimal            @map("invoiced_total") @db.Decimal(14, 2)
  matchStatus       InvoiceMatchStatus @default(PENDING) @map("match_status")
  // Variance approval — populated when matchStatus moves to APPROVED.
  approvedById      String?            @map("approved_by_id")
  approvedAt        DateTime?          @map("approved_at")
  // Authority-seam rule that authorised the variance, if any.
  authorityRuleId   String?            @map("authority_rule_id")
  notes             String?
  createdById       String             @map("created_by_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  lines         VendorInvoiceLine[]

  @@unique([purchaseOrderId, invoiceNumber])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([matchStatus])
  @@map("vendor_invoices")
}

// Per-line breakdown of a VendorInvoice — the "billed" column in the 3-way match.
// orderedQty and orderedUnitPrice come from the matched ProcurementLine (the PO side).
// receivedQty comes from the GoodsReceipt (receipt side — currently the request line
// quantity as recorded at RECEIVED status; a future GoodsReceipt model can refine this).
model VendorInvoiceLine {
  id              String   @id @default(cuid())
  invoiceId       String   @map("invoice_id")
  // Reference back to the ProcurementLine this line was matched against (nullable
  // for additional charges not in the PO).
  procurementLineId String? @map("procurement_line_id")
  description     String
  // Three-way quantities and prices.
  orderedQty      Decimal? @map("ordered_qty")      @db.Decimal(14, 4)
  receivedQty     Decimal? @map("received_qty")     @db.Decimal(14, 4)
  billedQty       Decimal  @map("billed_qty")       @db.Decimal(14, 4)
  orderedUnitPrice  Decimal? @map("ordered_unit_price")  @db.Decimal(14, 4)
  billedUnitPrice   Decimal  @map("billed_unit_price")   @db.Decimal(14, 4)
  billedLineTotal   Decimal  @map("billed_line_total")   @db.Decimal(14, 2)
  // Computed variance flags (filled in by the match run).
  qtyVariance       Decimal? @map("qty_variance")       @db.Decimal(14, 4)
  priceVariance     Decimal? @map("price_variance")     @db.Decimal(14, 4)
  // True when this line's variance exceeds the configured tolerance.
  withinTolerance   Boolean  @default(true) @map("within_tolerance")
  createdAt       DateTime @default(now()) @map("created_at")

  invoice VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([procurementLineId])
  @@map("vendor_invoice_lines")
}

// Reconcile / close audit record for a PurchaseOrder — one per PO, written
// when the PO is fully matched and signed-off. Feeds the project-close audit.
model PoReconcileAudit {
  id               String   @id @default(cuid())
  purchaseOrderId  String   @unique @map("purchase_order_id")
  reconciledById   String   @map("reconciled_by_id")
  reconciledAt     DateTime @map("reconciled_at")
  poTotal          Decimal  @map("po_total")       @db.Decimal(14, 2)
  invoicedTotal    Decimal  @map("invoiced_total") @db.Decimal(14, 2)
  // Net variance (invoicedTotal - poTotal); negative = under-billed.
  netVariance      Decimal  @map("net_variance")   @db.Decimal(14, 2)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@map("po_reconcile_audits")
}

// Singleton (id="singleton") â€" sourcing-gate value bands per POL 1.2.14.
// Under `minQuoteThreshold` â†' no quote evidence required. At or above â†' the
// operator must record `quoteEvidenceRef` on the request. At or above
// `rfqThreshold` a formal RFQ is expected. Numbers seeded, not hardcoded.
model ProcurementConfig {
  id                     String   @id
  minQuoteThreshold      Decimal  @default(5000)  @map("min_quote_threshold")       @db.Decimal(14, 2)
  requiredQuotesAtMin    Int      @default(3)     @map("required_quotes_at_min")
  rfqThreshold           Decimal  @default(20000) @map("rfq_threshold")              @db.Decimal(14, 2)
  // Three-way match tolerance (PR-629 slice 3). 0 = exact match required.
  matchQtyTolerancePct   Decimal  @default(0)     @map("match_qty_tolerance_pct")    @db.Decimal(5, 2)
  matchPriceTolerancePct Decimal  @default(0)     @map("match_price_tolerance_pct")  @db.Decimal(5, 2)
  updatedAt              DateTime @updatedAt      @map("updated_at")

  @@map("procurement_config")
}

// â"€â"€ Company Profile â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// SINGLETON identifying who "we" are â€" the one home for legalName, ABN,
// commercial defaults, document numbering prefixes, and branding. Read by
// every document builder (PDF, Excel, ICS), email sender, and AI prompt
// prefix. Enforced singleton: `id` is always the sentinel string
// "singleton" (application layer) plus a CHECK constraint at DB level for
// defense-in-depth (same pattern as `PlatformConfig`, but hardened â€" if
// you find yourself wanting a second row you want multi-tenancy, which is
// deliberately out of scope).
//
// legalName vs tradingName: two different fields on purpose. legalName
// appears on contracts, tax invoices, legal documents; tradingName is
// what users see in UI and emails. In Australian business practice they
// often differ (e.g. "Initial Services Group Pty Ltd" trading as
// "Initial Services"). Retrofitting the split later means auditing every
// document surface â€" do not collapse.
//
// Commercial defaults (gstRate, paymentTerms, markup, quote validity) are
// SEEDS for forms only. An explicit user choice on a tender/quote/job
// always wins. A default that silently overrides a user's entered value
// is a data-integrity bug, not a convenience.
enum CompanyEntityType {
  PTY_LTD
  SOLE_TRADER
  PARTNERSHIP
  TRUST
  OTHER
}

model CompanyProfile {
  id String @id // must always be "singleton" (enforced by CHECK constraint)

  // â"€ Identity â"€
  legalName   String            @map("legal_name")
  tradingName String            @map("trading_name")
  abn         String?
  acn         String?
  entityType  CompanyEntityType @default(PTY_LTD) @map("entity_type")

  // â"€ Contact â"€
  primaryEmail           String? @map("primary_email")
  primaryPhone           String? @map("primary_phone")
  website                String?
  registeredAddressLine1 String? @map("reg_address_line1")
  registeredAddressLine2 String? @map("reg_address_line2")
  registeredSuburb       String? @map("reg_suburb")
  registeredState        String? @map("reg_state")
  registeredPostcode     String? @map("reg_postcode")
  registeredCountry      String  @default("Australia") @map("reg_country")
  postalAddressLine1     String? @map("post_address_line1")
  postalAddressLine2     String? @map("post_address_line2")
  postalSuburb           String? @map("post_suburb")
  postalState            String? @map("post_state")
  postalPostcode         String? @map("post_postcode")
  postalCountry          String  @default("Australia") @map("post_country")

  // WHS officer. SetNull on user delete so we never orphan the profile.
  whsOfficerUserId String? @map("whs_officer_user_id")
  whsOfficer       User?   @relation("CompanyProfileWhsOfficer", fields: [whsOfficerUserId], references: [id], onDelete: SetNull)

  emergencyContactName  String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")

  // â"€ Commercial defaults (SEED forms; explicit user choice always wins) â"€
  gstRate                  Decimal @default(10) @map("gst_rate") @db.Decimal(5, 2)
  currency                 String  @default("AUD")
  financialYearStartMonth  Int     @default(7) @map("financial_year_start_month")
  timezone                 String  @default("Australia/Brisbane")
  defaultPaymentTermsDays  Int     @default(25) @map("default_payment_terms_days")
  defaultQuoteValidityDays Int     @default(30) @map("default_quote_validity_days")
  defaultMarkupPercent     Decimal @default(15) @map("default_markup_percent") @db.Decimal(5, 2)

  // â"€ Document numbering (format/prefix; counters live in *NumberSequence) â"€
  tenderNumberPrefix    String @default("T") @map("tender_number_prefix")
  quoteNumberPrefix     String @default("Q") @map("quote_number_prefix")
  jobNumberPrefix       String @default("J") @map("job_number_prefix")
  projectNumberPrefix   String @default("IS-P") @map("project_number_prefix")
  variationNumberPrefix String @default("V") @map("variation_number_prefix")
  claimNumberPrefix     String @default("PC") @map("claim_number_prefix")
  incidentNumberPrefix  String @default("INC") @map("incident_number_prefix")

  // â"€ Branding â"€
  // TODO: when BrandColorScheme + BrandAsset land (staged in pr-branding-manager),
  // replace these string fields with FKs. Until then, plain strings so the
  // profile is usable without a second migration.
  // â”€ Branding â”€
  // Legacy string columns kept as fallback while callers migrate to the
  // BrandColorScheme + BrandAsset relations below. A later contract PR
  // will drop these once every reader has been repointed.
  primaryColorHex   String  @default("#005B61") @map("primary_color_hex")
  secondaryColorHex String  @default("#FEAA6D") @map("secondary_color_hex")
  logoLightUrl      String? @map("logo_light_url")
  logoDarkUrl       String? @map("logo_dark_url")
  faviconUrl        String? @map("favicon_url")
  pdfLetterheadUrl  String? @map("pdf_letterhead_url")

  // â"€ Audit trail â"€
  activeColorSchemeId String?           @map("active_color_scheme_id")
  activeColorScheme   BrandColorScheme? @relation("CompanyProfileActiveColorScheme", fields: [activeColorSchemeId], references: [id], onDelete: SetNull)
  brandAssets         BrandAsset[]      @relation("CompanyProfileBrandAssets")

  // â”€ Audit trail â”€
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  licences       EntityLicence[]        @relation("CompanyLicences")
  insurances     EntityInsurance[]      @relation("CompanyInsurances")
  legalDocuments CompanyLegalDocument[]

  @@map("company_profile")
}

// Named palette of brand colours. Additive to CompanyProfile.primaryColorHex /
// secondaryColorHex — the singleton points at a scheme via activeColorSchemeId
// while the string fallbacks stay in place until a later contract PR removes
// them. Only super-users mutate these (BrandingController enforces).
model BrandColorScheme {
  id                String   @id @default(cuid())
  name              String   @unique
  primaryColorHex   String   @map("primary_color_hex")
  secondaryColorHex String   @map("secondary_color_hex")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  activeOn CompanyProfile[] @relation("CompanyProfileActiveColorScheme")

  @@map("brand_color_scheme")
}

enum BrandAssetKind {
  LOGO_LIGHT
  LOGO_DARK
  FAVICON
  PDF_LETTERHEAD
}

// Per-kind asset URLs for the CompanyProfile singleton. Additive to the
// legacy logoLightUrl / logoDarkUrl / faviconUrl / pdfLetterheadUrl columns.
// (@@unique on profileId + kind enforces one asset per kind per profile.)
model BrandAsset {
  id        String         @id @default(cuid())
  profileId String         @default("singleton") @map("profile_id")
  profile   CompanyProfile @relation("CompanyProfileBrandAssets", fields: [profileId], references: [id], onDelete: Cascade)
  kind      BrandAssetKind
  url       String
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([profileId, kind])
  @@map("brand_asset")
}

// Effective-dated, versioned company legal documents. Editing content
// creates a NEW row; never mutates an issued version. Every issued
// ClientQuote / Contract pins the T&C version via `issuedTermsDocumentId`
// so a March-issued quote forever renders March's T&Cs even if the current
// version is edited in September.
//
// Rationale: for a demolition contractor a quote/contract is a binding
// agreement. Silently rewriting the terms attached to historical quotes
// is not a cosmetic bug â€" it is a contractual and evidentiary problem.
enum CompanyLegalDocumentType {
  TERMS_AND_CONDITIONS
  COVER_LETTER
  STANDARD_ASSUMPTIONS
  STANDARD_EXCLUSIONS
  PROJECT_ALLOWANCES
  PRIVACY_NOTICE
}

model CompanyLegalDocument {
  id            String                   @id @default(cuid())
  profileId     String                   @default("singleton") @map("profile_id")
  profile       CompanyProfile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type          CompanyLegalDocumentType
  version       Int
  content       String
  effectiveFrom DateTime                 @map("effective_from")
  effectiveTo   DateTime?                @map("effective_to")
  isActive      Boolean                  @default(true) @map("is_active")

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("CompanyLegalDocCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  issuedOnQuotes    ClientQuote[] @relation("QuoteIssuedTerms")
  issuedOnContracts Contract[]    @relation("ContractIssuedTerms")

  @@unique([type, version])
  @@index([type, isActive])
  @@map("company_legal_documents")
}

// ── Commitments (ERP gap A — cost control) ─────────────────────────────────
// Committed costs (subcontracts, purchase orders to tip sites / haulage /
// plant hire / subbies) tracked against a Job budget. Distinct from
// ProcurementRequest (an internal purchase-requisition workflow); a
// Commitment is the budget-facing record of a contracted spend obligation.
//
// Budget view equation: budget vs committed vs actual (actuals posted by
// Accounts outside this system for now — a separate PR will wire them).
//
// CommitmentChange captures scope variations / VO to the original value.

enum CommitmentType {
  SUBCONTRACT
  PURCHASE_ORDER
  HIRE
  OTHER
}

enum CommitmentStatus {
  DRAFT
  APPROVED
  CLOSED
  CANCELLED
}

enum CommitmentChangeStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Commitment {
  id              String                 @id @default(cuid())
  jobId           String                 @map("job_id")
  job             Job                    @relation(fields: [jobId], references: [id], onDelete: Restrict)
  type            CommitmentType
  supplierId      String?                @map("supplier_id")
  supplier        SubcontractorSupplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  reference       String
  description     String
  value           Decimal                @db.Decimal(14, 2)
  status          CommitmentStatus       @default(DRAFT)
  // Optional link to the procurement PO that triggered this commitment.
  purchaseOrderId String?                @unique @map("purchase_order_id")
  createdById     String                 @map("created_by_id")
  createdBy       User                   @relation("CommitmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  items   CommitmentItem[]
  changes CommitmentChange[]

  @@index([jobId, status])
  @@index([supplierId])
  @@map("commitments")
}

model CommitmentItem {
  id           String   @id @default(cuid())
  commitmentId String   @map("commitment_id")
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  description  String
  costCategory String?  @map("cost_category")
  quantity     Decimal  @default(1) @db.Decimal(14, 4)
  unit         String   @default("lump")
  rate         Decimal? @db.Decimal(14, 2)
  amount       Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([commitmentId])
  @@map("commitment_items")
}

model CommitmentChange {
  id            String                 @id @default(cuid())
  commitmentId  String                 @map("commitment_id")
  commitment    Commitment             @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  reference     String
  description   String
  valueChange   Decimal                @map("value_change") @db.Decimal(14, 2)
  status        CommitmentChangeStatus @default(DRAFT)
  approvedById  String?                @map("approved_by_id")
  approvedBy    User?                  @relation("CommitmentChangeApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdById   String                 @map("created_by_id")
  createdBy     User                   @relation("CommitmentChangeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([commitmentId, status])
  @@map("commitment_changes")
}
