model UserAiPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedProviderId  String?  @map("last_used_provider_id")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("user_ai_preferences")
}

// ── Projects module (PR #39) ─────────────────────────────────────────────
// Project records live alongside Job (delivery-side) and are produced by the
// tender→project conversion flow. IS-P### numbers are issued from a locked
// sequence row at conversion time.

enum ProjectStatus {
  MOBILISING
  ACTIVE
  PRACTICAL_COMPLETION
  DEFECTS
  CLOSED
}

enum ProjectActivityAction {
  PROJECT_CREATED
  STATUS_CHANGED
  TEAM_CHANGED
  CONTRACT_VALUE_CHANGED
  BUDGET_CHANGED
  DOCUMENT_ADDED
  DOCUMENT_REMOVED
  WORKER_ALLOCATED
  ASSET_ALLOCATED
  TIMESHEET_SUBMITTED
  TIMESHEET_REJECTED
  PRESTART_SUBMITTED
}

enum AllocationTargetType {
  WORKER
  ASSET
}

model ProjectNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("project_number_sequences")
}

model Project {
  id                      String         @id @default(cuid())
  projectNumber           String         @unique @map("project_number")
  name                    String
  status                  ProjectStatus  @default(MOBILISING)
  sourceTenderId          String?        @map("source_tender_id")
  sourceTender            Tender?        @relation(fields: [sourceTenderId], references: [id], onDelete: SetNull)
  clientId                String         @map("client_id")
  client                  Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  siteAddressLine1        String         @map("site_address_line1")
  siteAddressLine2        String?        @map("site_address_line2")
  siteAddressSuburb       String         @map("site_address_suburb")
  siteAddressState        String         @map("site_address_state")
  siteAddressPostcode     String         @map("site_address_postcode")
  contractValue           Decimal        @default(0) @db.Decimal(12, 2) @map("contract_value")
  budget                  Decimal        @default(0) @db.Decimal(12, 2)
  actualCost              Decimal        @default(0) @db.Decimal(12, 2) @map("actual_cost")
  proposedStartDate       DateTime?      @map("proposed_start_date")
  actualStartDate         DateTime?      @map("actual_start_date")
  practicalCompletionDate DateTime?      @map("practical_completion_date")
  closedDate              DateTime?      @map("closed_date")
  projectManagerId        String?        @map("project_manager_id")
  projectManager          User?          @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  supervisorId            String?        @map("supervisor_id")
  supervisor              User?          @relation("ProjectSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  estimatorId             String?        @map("estimator_id")
  estimator               User?          @relation("ProjectEstimator", fields: [estimatorId], references: [id], onDelete: SetNull)
  whsOfficerId            String?        @map("whs_officer_id")
  whsOfficer              User?          @relation("ProjectWHS", fields: [whsOfficerId], references: [id], onDelete: SetNull)
  estimateSnapshot        Json           @map("estimate_snapshot")
  createdById             String         @map("created_by_id")
  createdBy               User           @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  scopeItems              ProjectScopeItem[]
  milestones              ProjectMilestone[]
  activityLog             ProjectActivityLog[]
  documents               TenderDocumentLink[]
  allocations             ProjectAllocation[]
  preStartChecklists      PreStartChecklist[]
  timesheets              Timesheet[]
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([clientId])
  @@index([sourceTenderId])
  @@map("projects")
}

model ProjectScopeItem {
  id                   String  @id @default(cuid())
  projectId            String  @map("project_id")
  project              Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeCode            String  @map("scope_code")
  description          String
  quantity             Decimal @db.Decimal(10, 3)
  unit                 String
  sourceEstimateLineId String? @map("source_estimate_line_id")

  @@index([projectId, scopeCode])
  @@map("project_scope_items")
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  plannedDate DateTime? @map("planned_date")
  actualDate  DateTime? @map("actual_date")
  status      String    @default("PENDING")
  order       Int       @default(0)

  @@index([projectId, order])
  @@map("project_milestones")
}

model ProjectActivityLog {
  id        String                @id @default(cuid())
  projectId String                @map("project_id")
  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String                @map("user_id")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  action    ProjectActivityAction
  details   Json
  createdAt DateTime              @default(now()) @map("created_at")

  @@index([projectId, createdAt])
  @@map("project_activity_logs")
}

// ── Resource Allocation module (PR #40) ───────────────────────────────────
// WorkerProfile is the HR/compliance-facing staff record. It is separate from
// the scheduler-facing Worker model (which carries crew/shift/availability
// wiring). A WorkerProfile becomes an internal login once Mobile Access is
// provisioned (internalUserId → User).
//
// ProjectAllocation joins either a WorkerProfile OR an Asset onto a Project
// over a date range. Type constraints are enforced in the service layer so
// the table stays a flat join.

model WorkerProfile {
  id                    String              @id @default(cuid())
  firstName             String              @map("first_name")
  lastName              String              @map("last_name")
  preferredName         String?             @map("preferred_name")
  role                  String
  phone                 String?
  email                 String?             @unique
  emergencyContactName  String?             @map("emergency_contact_name")
  emergencyContactPhone String?             @map("emergency_contact_phone")
  licenceNumber         String?             @map("licence_number")
  licenceClass          String?             @map("licence_class")
  ticketNumbers         String?             @map("ticket_numbers")
  hasMobileAccess       Boolean             @default(false) @map("has_mobile_access")
  internalUserId        String?             @unique @map("internal_user_id")
  internalUser          User?               @relation(fields: [internalUserId], references: [id], onDelete: SetNull)
  isActive              Boolean             @default(true) @map("is_active")
  allocations           ProjectAllocation[]
  preStartChecklists    PreStartChecklist[]
  timesheets            Timesheet[]
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([lastName, firstName])
  @@map("worker_profiles")
}

model ProjectAllocation {
  id              String               @id @default(cuid())
  projectId       String               @map("project_id")
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            AllocationTargetType
  workerProfileId String?              @map("worker_profile_id")
  workerProfile   WorkerProfile?       @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  assetId         String?              @map("asset_id")
  asset           Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  roleOnProject   String?              @map("role_on_project")
  startDate       DateTime             @map("start_date")
  endDate         DateTime?            @map("end_date")
  notes           String?
  createdById     String               @map("created_by_id")
  createdBy       User                 @relation("ProjectAllocationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  preStartChecklists PreStartChecklist[]
  timesheets      Timesheet[]
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([projectId, type])
  @@index([workerProfileId, startDate])
  @@index([assetId, startDate])
  @@map("project_allocations")
}

// ── Field Worker Experience (PR #41) ──────────────────────────────────────
// PreStartChecklist + Timesheet are field-submitted records keyed to a worker
// (WorkerProfile) + their allocation on a project. DRAFT records are editable
// by the worker; SUBMITTED locks the record and fires a notification + a
// project activity log entry. Timesheet has an additional APPROVED state set
// by a user with field.manage.

enum PreStartStatus {
  DRAFT
  SUBMITTED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model PreStartChecklist {
  id                    String          @id @default(cuid())
  projectId             String          @map("project_id")
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerProfileId       String          @map("worker_profile_id")
  workerProfile         WorkerProfile   @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  allocationId          String          @map("allocation_id")
  allocation            ProjectAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  date                  DateTime
  status                PreStartStatus  @default(DRAFT)
  supervisorName        String?         @map("supervisor_name")
  supervisorSignedAt    DateTime?       @map("supervisor_signed_at")

  siteHazardsAcknowledged   Boolean   @default(false) @map("site_hazards_acknowledged")
  hazardNotes               String?   @map("hazard_notes")

  ppeHelmet                 Boolean   @default(false) @map("ppe_helmet")
  ppeGloves                 Boolean   @default(false) @map("ppe_gloves")
  ppeBoots                  Boolean   @default(false) @map("ppe_boots")
  ppeHighVis                Boolean   @default(false) @map("ppe_high_vis")
  ppeRespirator             Boolean   @default(false) @map("ppe_respirator")
  ppeOther                  String?   @map("ppe_other")

  plantChecksCompleted      Boolean   @default(false) @map("plant_checks_completed")
  plantCheckNotes           String?   @map("plant_check_notes")

  fitForWork                Boolean   @default(false) @map("fit_for_work")
  fitForWorkDeclaration     String?   @map("fit_for_work_declaration")
  workerSignature           String?   @map("worker_signature")
  workerSignedAt            DateTime? @map("worker_signed_at")

  asbEnclosureInspection    Boolean?  @map("asb_enclosure_inspection")
  asbAirMonitoring          Boolean?  @map("asb_air_monitoring")
  asbDeconOperational       Boolean?  @map("asb_decon_operational")

  civExcavationPermit       Boolean?  @map("civ_excavation_permit")
  civUndergroundClearance   Boolean?  @map("civ_underground_clearance")

  submittedAt               DateTime? @map("submitted_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@unique([workerProfileId, allocationId, date])
  @@index([projectId, date])
  @@index([workerProfileId, date])
  @@index([status])
  @@map("pre_start_checklists")
}

model Timesheet {
  id                String            @id @default(cuid())
  projectId         String            @map("project_id")
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerProfileId   String            @map("worker_profile_id")
  workerProfile     WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  allocationId      String            @map("allocation_id")
  allocation        ProjectAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  date              DateTime
  hoursWorked       Decimal           @db.Decimal(4, 2) @map("hours_worked")
  breakMinutes      Int               @default(0) @map("break_minutes")
  description       String?
  clockOnTime       DateTime?         @map("clock_on_time")
  clockOffTime      DateTime?         @map("clock_off_time")
  status            TimesheetStatus   @default(DRAFT)
  submittedAt       DateTime?         @map("submitted_at")
  approvedById      String?           @map("approved_by_id")
  approvedBy        User?             @relation("TimesheetApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?         @map("approved_at")
  rejectedReason    String?           @map("rejected_reason")
  rejectedById      String?           @map("rejected_by_id")
  rejectedBy        User?             @relation("TimesheetRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt        DateTime?         @map("rejected_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@unique([workerProfileId, allocationId, date])
  @@index([projectId, date])
  @@index([workerProfileId, date])
  @@index([status])
  @@map("timesheets")
}

// ── Scope of Works (PR #44) ───────────────────────────────────────────────
// Interactive QS sheet — sits between the tender documents and the
// estimate. Rows are discipline-typed and carry row-type-specific fields
// (demolition sqm, cutting lm, asbestos ACM, excavation m3, waste tonnes,
// plant days). AI-drafted rows start as status="draft", aiProposed=true;
// confirming a row triggers auto-creation of the matching EstimateItem.
model ScopeOfWorksItem {
  id            String   @id @default(uuid())
  tenderId      String   @map("tender_id")
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  wbsCode       String   @map("wbs_code")
  discipline    String
  itemNumber    Int      @map("item_number")
  rowType       String   @map("row_type")
  description   String
  status        String   @default("confirmed")
  aiProposed    Boolean  @default(false) @map("ai_proposed")
  aiConfidence  String?  @map("ai_confidence")
  aiSourceRef   String?  @map("ai_source_ref")
  sortOrder     Int      @default(0) @map("sort_order")
  notes         String?

  // General (all rows)
  men   Decimal? @db.Decimal(8, 2)
  days  Decimal? @db.Decimal(8, 2)
  shift String?

  // Demolition
  sqm          Decimal? @db.Decimal(10, 2)
  m3           Decimal? @db.Decimal(10, 2)
  materialType String?  @map("material_type")

  // Cutting
  cuttingEquipment   String?  @map("cutting_equipment")
  elevation          String?
  depthMm            Int?     @map("depth_mm")
  lm                 Decimal? @db.Decimal(10, 2)
  coreHoleDiameterMm Int?     @map("core_hole_diameter_mm")
  coreHoleQty        Decimal? @db.Decimal(10, 2) @map("core_hole_qty")

  // Asbestos
  acmType           String?  @map("acm_type")
  acmMaterial       String?  @map("acm_material")
  enclosureRequired Boolean? @map("enclosure_required")
  airMonitoring     Boolean? @map("air_monitoring")

  // Excavation / civil
  excavationDepthM   Decimal? @db.Decimal(8, 2) @map("excavation_depth_m")
  excavationMaterial String?  @map("excavation_material")
  machineSize        String?  @map("machine_size")

  // Waste / disposal
  wasteGroup    String?  @map("waste_group")
  wasteType     String?  @map("waste_type")
  wasteFacility String?  @map("waste_facility")
  wasteTonnes   Decimal? @db.Decimal(10, 3) @map("waste_tonnes")
  wasteLoads    Int?     @map("waste_loads")
  wasteM3       Decimal? @db.Decimal(10, 2) @map("waste_m3")

  // Redesign additions — generic measurement + material + plant FK.
  // The legacy sqm/m3/materialType/assetId columns are kept so old rows
  // render unchanged; new UI writes to these.
  measurementQty  Decimal? @db.Decimal(12, 3) @map("measurement_qty")
  measurementUnit String?  @map("measurement_unit")
  material        String?
  plantAssetId    String?  @map("plant_asset_id")
  plantAsset      Asset?   @relation("ScopeItemPlant", fields: [plantAssetId], references: [id], onDelete: SetNull)

  // Provisional sum amount (discipline=Prv only). Final price = this value,
  // no markup applied. Ignored for non-Prv rows.
  provisionalAmount Decimal? @db.Decimal(12, 2) @map("provisional_amount")

  // Plant days
  excavatorDays  Decimal? @db.Decimal(8, 2) @map("excavator_days")
  bobcatDays     Decimal? @db.Decimal(8, 2) @map("bobcat_days")
  ewpDays        Decimal? @db.Decimal(8, 2) @map("ewp_days")
  hookTruckDays  Decimal? @db.Decimal(8, 2) @map("hook_truck_days")
  semiTipperDays Decimal? @db.Decimal(8, 2) @map("semi_tipper_days")
  assetId        String?  @map("asset_id")

  estimateItemId String?  @map("estimate_item_id")
  createdById    String   @map("created_by_id")
  createdBy      User     @relation("ScopeOfWorksCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, discipline, itemNumber])
  @@index([tenderId, status])
  @@map("scope_of_works_items")
}

model ScopeOfWorksHeader {
  id                String    @id @default(uuid())
  tenderId          String    @unique @map("tender_id")
  tender            Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  siteAddress       String?   @map("site_address")
  siteContactName   String?   @map("site_contact_name")
  siteContactPhone  String?   @map("site_contact_phone")
  accessConstraints String?   @map("access_constraints")
  proposedStartDate DateTime? @map("proposed_start_date")
  durationWeeks     Int?      @map("duration_weeks")
  specialConditions String?   @map("special_conditions")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("scope_of_works_headers")
}

// ── Estimate export audit trail (PR #45) ──────────────────────────────────
// One row per PDF / Excel export. Server-side recalc runs on every export;
// nothing about the stored lines changes, we just keep a log of who
// generated what and when so the audit view can surface it.
model EstimateExport {
  id          String   @id @default(cuid())
  tenderId    String   @map("tender_id")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  type        String
  generatedAt DateTime @default(now()) @map("generated_at")
  generatedBy String   @map("generated_by")
  user        User     @relation(fields: [generatedBy], references: [id], onDelete: Restrict)
  filePath    String?  @map("file_path")
  version     Int      @default(1)

  @@index([tenderId])
  @@map("estimate_exports")
}

// ── Global Lists ────────────────────────────────────────────────────────
// User-manageable reference data (materials, measurement units, row types,
// etc.) plus dynamic lists that proxy to other modules (assets, workers).
// Items are archived, never hard-deleted — the `value` string is stored
// verbatim on the consuming record, so archived items still render on
// existing rows but drop out of dropdowns for new entries.
enum GlobalListType {
  STATIC
  DYNAMIC
}

model GlobalList {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  description  String?
  type         GlobalListType
  sourceModule String?          @map("source_module")
  isSystem     Boolean          @default(false) @map("is_system")
  createdById  String           @map("created_by_id")
  createdBy    User             @relation("GlobalListCreatedBy", fields: [createdById], references: [id])
  items        GlobalListItem[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("global_lists")
}

model GlobalListItem {
  id          String     @id @default(cuid())
  listId      String     @map("list_id")
  list        GlobalList @relation(fields: [listId], references: [id], onDelete: Cascade)
  value       String
  label       String
  metadata    Json?
  sortOrder   Int        @default(0) @map("sort_order")
  isArchived  Boolean    @default(false) @map("is_archived")
  createdById String     @map("created_by_id")
  createdBy   User       @relation("GlobalListItemCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([listId, value])
  @@index([listId, isArchived])
  @@map("global_list_items")
}

// ── Tender Clarification Notes ─────────────────────────────────────────
// Simple sent/received communication log for a tender — the existing
// TenderClarification model is a different shape (Q&A with status/dueDate)
// used by the follow-up queue, so this is a parallel model for the
// Overview-tab clarifications log.
model TenderClarificationNote {
  id          String   @id @default(cuid())
  tenderId    String   @map("tender_id")
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  direction   String
  text        String
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdById String   @map("created_by_id")
  createdBy   User     @relation("TenderClarificationNoteAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenderId, occurredAt])
  @@map("tender_clarification_notes")
}

// ── Scope redesign — view config + cutting sheet ───────────────────────
// ScopeViewConfig persists which optional columns the user has enabled
// for a given (tender × discipline) combination. The server owns the set
// of available columns per row type; this model only remembers the
// user's current selection so the UI can restore it after reload.
model ScopeViewConfig {
  id         String   @id @default(cuid())
  tenderId   String   @map("tender_id")
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  discipline String
  columns    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenderId, discipline])
  @@map("scope_view_configs")
}

// CuttingSheetItem is the concrete-cutting line-item store used by the
// Cutting Sheet tab of the Scope of Works redesign. It is tender-scoped
// (not estimate-item-scoped like the legacy EstimateCuttingLine) so it
// can be edited independently of estimate lines. Rate lookups and
// lineTotal calculations are performed server-side at write time.
model CuttingSheetItem {
  id            String   @id @default(cuid())
  tenderId      String   @map("tender_id")
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  wbsRef        String   @map("wbs_ref")
  description   String?
  itemType      String   @map("item_type") // saw-cut | core-hole
  equipment     String?
  elevation     String?                      // Floor | Wall | Inverted
  material      String?
  depthMm       Int?     @map("depth_mm")
  diameterMm    Int?     @map("diameter_mm")
  quantityLm    Decimal? @db.Decimal(10, 2) @map("quantity_lm")
  quantityEach  Int?     @map("quantity_each")
  ratePerM      Decimal? @db.Decimal(10, 4) @map("rate_per_m")
  ratePerHole   Decimal? @db.Decimal(10, 4) @map("rate_per_hole")
  lineTotal     Decimal? @db.Decimal(12, 2) @map("line_total")
  shift         String?
  shiftLoading  Decimal? @db.Decimal(10, 2) @map("shift_loading")
  notes         String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdById   String   @map("created_by_id")
  createdBy     User     @relation("CuttingSheetItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenderId, itemType, sortOrder])
  @@map("cutting_sheet_items")
}

// ── Quote tab — T&C, Assumptions, Exclusions ────────────────────────────
// Per-tender editable copies. T&Cs seed from tc-text.const.ts on first read.
// Assumptions/exclusions pre-populate from IS standards on first list load
// (handled in the service) if the tender has none yet.
model TenderTandC {
  id        String   @id @default(cuid())
  tenderId  String   @unique @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  clauses   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tender_tandc")
}

model TenderAssumption {
  id        String   @id @default(cuid())
  tenderId  String   @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, sortOrder])
  @@map("tender_assumptions")
}

model TenderExclusion {
  id        String   @id @default(cuid())
  tenderId  String   @map("tender_id")
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenderId, sortOrder])
  @@map("tender_exclusions")
}

// ── Admin Settings ──────────────────────────────────────────────────────
// One row per notification trigger. isEnabled=false means "system-wide off"
// — even if an individual user opts in via their /account page they still
// won't receive it. Recipients are a union of role-based (roleNames) and
// user-id-based (recipientUserIds) addressees.
model NotificationTriggerConfig {
  id               String   @id @default(cuid())
  trigger          String   @unique
  label            String
  description      String
  isEnabled        Boolean  @default(false) @map("is_enabled")
  deliveryMethod   String   @default("both") @map("delivery_method")
  recipientRoles   String[] @map("recipient_roles")
  recipientUserIds String[] @map("recipient_user_ids")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("notification_trigger_configs")
}

// Singleton row (id="singleton") holding the active email provider + sender
// identity. Provider credentials themselves continue to live in env vars
// (SHAREPOINT_* doubles as Graph Mail credentials in practice), so this
// model only stores the mutable presentation/selection details.
model EmailProviderConfig {
  id            String   @id @default("singleton")
  provider      String   @default("outlook")
  senderAddress String   @default("marco@initialservices.net") @map("sender_address")
  senderName    String   @default("Initial Services") @map("sender_name")
  isConfigured  Boolean  @default(false) @map("is_configured")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id")
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("email_provider_config")
}
