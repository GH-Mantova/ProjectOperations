  site               Site                   @relation(fields: [siteId], references: [id], onDelete: Restrict)
  sourceTender       Tender?                @relation(fields: [sourceTenderId], references: [id], onDelete: SetNull)
  survivingProject   Project?               @relation("JobSurvivingProject", fields: [survivingProjectId], references: [id], onDelete: SetNull)
  reverseSourceOf    Project?               @relation("ProjectSourceJob")
