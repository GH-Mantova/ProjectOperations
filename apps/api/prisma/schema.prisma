// â”€â”€â”€ Worker availability (PR #85) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
//
// â"€â"€â"€ Worker availability (PR #85) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Two distinct concepts:
//   WorkerLeave         â€" approved time off with type (annual/sick/personal/...)
//   WorkerUnavailability â€" soft holds for recurring or ad-hoc days the worker
//                          cannot be allocated (e.g. RDO, training, ticket renewal)
// Scheduler reads both and overlays them on the calendar; create-shift flow
// surfaces conflicts so the planner can re-pick a worker without committing.

model WorkerLeave {
  id              String        @id @default(cuid())
  workerProfileId String        @map("worker_profile_id")
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  leaveType       String        @map("leave_type")
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  status          String        @default("PENDING")
  notes           String?
  requestedById   String?       @map("requested_by_id")
  requestedBy     User?         @relation("WorkerLeaveRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedById    String?       @map("approved_by_id")
  approvedBy      User?         @relation("WorkerLeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?     @map("approved_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([workerProfileId, startDate])
  @@index([status])
  @@map("worker_leaves")
}

model WorkerUnavailability {
  id              String        @id @default(cuid())
  workerProfileId String        @map("worker_profile_id")
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reason          String
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  recurringDay    Int?          @map("recurring_day")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([workerProfileId, startDate])
  @@map("worker_unavailability")
}

// â"€â"€â"€ GPS clock-on (PR #84) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// One row per geolocation reading associated with a clock-on or clock-off
// event. We log raw points (separate from the timesheet snapshot) so audits
// can show how location was sampled â€" e.g. multiple reads for accuracy.

model WorkerLocationLog {
  id              String        @id @default(cuid())
  workerProfileId String        @map("worker_profile_id")
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  timesheetId     String?       @map("timesheet_id")
  eventType       String        @map("event_type")
  latitude        Decimal       @db.Decimal(9, 6)
  longitude       Decimal       @db.Decimal(9, 6)
  accuracy        Decimal?      @db.Decimal(8, 2)
  recordedAt      DateTime      @default(now()) @map("recorded_at")

  @@index([workerProfileId, recordedAt])
  @@index([timesheetId])
  @@map("worker_location_logs")
}

// â"€â"€â"€ Client Portal (PR #83) â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€

model ClientPortalUser {
  id                 String          @id @default(cuid())
  clientId           String          @map("client_id")
  client             Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email              String          @unique
  passwordHash       String          @map("password_hash")
  firstName          String          @map("first_name")
  lastName           String          @map("last_name")
  phone              String?
  isActive           Boolean         @default(true) @map("is_active")
  forcePasswordReset Boolean         @default(false) @map("force_password_reset")
  lastLoginAt        DateTime?       @map("last_login_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  sessions           PortalSession[]

  @@index([clientId])
  @@index([email])
  @@map("client_portal_users")
}

model PortalSession {
  id           String           @id @default(cuid())
  portalUserId String           @map("portal_user_id")
  portalUser   ClientPortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  tokenHash    String           @map("token_hash")
  expiresAt    DateTime         @map("expires_at")
  revokedAt    DateTime?        @map("revoked_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([portalUserId])
