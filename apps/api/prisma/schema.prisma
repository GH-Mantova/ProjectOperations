model FormTemplate {
  id                 String                @id @default(cuid())
  name               String
  code               String                @unique
  description        String?
  status             String                @default("DRAFT")
  geolocationEnabled Boolean               @default(false) @map("geolocation_enabled")
  associationScopes  Json?                 @map("association_scopes")
  // PR #97 Forms Engine — category + system flag + settings blob.
  // category: safety|asbestos|plant|induction|environmental|permits|quality|daily|custom
  // settings: { requiresApproval, approvalChain[], geofenceEnabled, allowOffline,
  //             pdfExport, complianceGate{} }
  category           String                @default("custom")
  isSystemTemplate   Boolean               @default(false) @map("is_system_template")
  settings           Json                  @default("{}")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  versions           FormTemplateVersion[]
  schedules          FormSchedule[]

  @@index([status])
  @@index([category])
  @@map("form_templates")
}

model FormTemplateVersion {
  id            String           @id @default(cuid())
  templateId    String           @map("template_id")
  versionNumber Int              @map("version_number")
  status        String           @default("ACTIVE")
  createdAt     DateTime         @default(now()) @map("created_at")
  template      FormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sections      FormSection[]
  rules         FormRule[]
  submissions   FormSubmission[]

  @@unique([templateId, versionNumber])
  @@index([templateId, status])
  @@map("form_template_versions")
}

model FormSection {
  id           String              @id @default(cuid())
  versionId    String              @map("version_id")
  title        String
  description  String?
  sectionOrder Int                 @map("section_order")
  // PR #97 — repeating sections + section-level visibility conditions
  isRepeating  Boolean             @default(false) @map("is_repeating")
  minRepeat    Int?                @map("min_repeat")
  maxRepeat    Int?                @map("max_repeat")
  conditions   Json                @default("[]")
  createdAt    DateTime            @default(now()) @map("created_at")
  version      FormTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  fields       FormField[]

  @@index([versionId, sectionOrder])
  @@map("form_sections")
}

model FormField {
  id           String                @id @default(cuid())
  sectionId    String                @map("section_id")
  fieldKey     String                @map("field_key")
  label        String
  fieldType    String                @map("field_type")
  fieldOrder   Int                   @map("field_order")
  isRequired   Boolean               @default(false) @map("is_required")
  placeholder  String?
  helpText     String?               @map("help_text")
  optionsJson  Json?                 @map("options_json")
  // PR #97 — generic field config + per-field rule attachments
  // config: field-type-specific settings (min/max/step, formula, lookup spec, etc.)
  // conditions: array of FieldRule objects evaluated by RulesEngineService
  // validations: extra validation rules beyond isRequired
  // actions: on_change actions (set_value, show, hide, send_notification, create_record)
  isReadOnly   Boolean               @default(false) @map("is_read_only")
  defaultValue String?               @map("default_value")
  config       Json                  @default("{}")
  conditions   Json                  @default("[]")
  validations  Json                  @default("[]")
  actions      Json                  @default("[]")
  createdAt    DateTime              @default(now()) @map("created_at")
  section      FormSection           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  values       FormSubmissionValue[]

  @@unique([sectionId, fieldKey])
  @@index([sectionId, fieldOrder])
  @@map("form_fields")
}

model FormRule {
  id              String              @id @default(cuid())
  versionId       String              @map("version_id")
  sourceFieldKey  String              @map("source_field_key")
  targetFieldKey  String              @map("target_field_key")
  operator        String
  comparisonValue String?             @map("comparison_value")
  effect          String              @default("SHOW")
  createdAt       DateTime            @default(now()) @map("created_at")
  version         FormTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("form_rules")
}

model FormSubmission {
  id                String                @id @default(cuid())
  templateVersionId String                @map("template_version_id")
  status            String                @default("SUBMITTED")
  submittedAt       DateTime              @default(now()) @map("submitted_at")
  submittedById     String?               @map("submitted_by_id")
  jobId             String?               @map("job_id")
  clientId          String?               @map("client_id")
  assetId           String?               @map("asset_id")
  workerId          String?               @map("worker_id")
  siteId            String?               @map("site_id")
  shiftId           String?               @map("shift_id")
  supplierName      String?               @map("supplier_name")
  geolocation       String?
  summary           String?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  templateVersion   FormTemplateVersion   @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  submittedBy       User?                 @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  job               Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  client            Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset             Asset?                @relation(fields: [assetId], references: [id], onDelete: SetNull)
  worker            Worker?               @relation(fields: [workerId], references: [id], onDelete: SetNull)
  site              Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  shift             Shift?                @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  values            FormSubmissionValue[]
  attachments       FormAttachment[]
  signatures        FormSignature[]
  // PR #97 — auto-populated context blob, GPS lat/lng, approval chain rows,
  // and links back to records auto-created by submit-time actions
  context           Json                  @default("{}")
  gpsLat            Decimal?              @map("gps_lat") @db.Decimal(10, 7)
  gpsLng            Decimal?              @map("gps_lng") @db.Decimal(10, 7)
  approvals         FormApproval[]
  triggeredRecords  FormTriggeredRecord[]

  @@index([templateVersionId, submittedAt])
  @@index([jobId])
  @@index([assetId])
  @@index([workerId])
  @@index([shiftId])
  @@map("form_submissions")
}

// ─── Forms Engine (PR #97) — approvals, triggered records, schedules ─────

model FormApproval {
  id             String         @id @default(cuid())
  submissionId   String         @map("submission_id")
  submission     FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  stepNumber     Int            @map("step_number")
  assignedToId   String?        @map("assigned_to_id")
  assignedTo     User?          @relation("FormApprovalAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToRole String?        @map("assigned_to_role")
  status         String         @default("pending")
  comment        String?
  decidedAt      DateTime?      @map("decided_at")
  dueAt          DateTime?      @map("due_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([submissionId])
  @@index([assignedToId])
  @@index([status])
  @@map("form_approvals")
}

model FormTriggeredRecord {
  id           String         @id @default(cuid())
  submissionId String         @map("submission_id")
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  recordType   String         @map("record_type")
  recordId     String         @map("record_id")
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([submissionId])
  @@index([recordType, recordId])
  @@map("form_triggered_records")
}

model FormSchedule {
  id             String       @id @default(cuid())
  templateId     String       @map("template_id")
  template       FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scheduleType   String       @map("schedule_type")
  cronExpression String?      @map("cron_expression")
  eventTrigger   String?      @map("event_trigger")
  assignToRole   String?      @map("assign_to_role")
  assignToUserId String?      @map("assign_to_user_id")
  assignToUser   User?        @relation("FormScheduleAssignee", fields: [assignToUserId], references: [id], onDelete: SetNull)
  isActive       Boolean      @default(true) @map("is_active")
  lastRunAt      DateTime?    @map("last_run_at")
  nextRunAt      DateTime?    @map("next_run_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([templateId])
  @@index([nextRunAt])
  @@map("form_schedules")
}

model FormSubmissionValue {
  id            String         @id @default(cuid())
  submissionId  String         @map("submission_id")
  fieldId       String?        @map("field_id")
  fieldKey      String         @map("field_key")
  valueText     String?        @map("value_text")
  valueNumber   Decimal?       @map("value_number") @db.Decimal(14, 2)
  valueDateTime DateTime?      @map("value_date_time")
  valueJson     Json?          @map("value_json")
  // PR #97 — boolean answer + per-value file pointer (photos, signatures live
  // on FormAttachment / FormSignature; this lets simple file fields point
  // straight at a SharePoint or filesystem path without spawning rows there)
  valueBoolean  Boolean?       @map("value_boolean")
  filePath      String?        @map("file_path")
  createdAt     DateTime       @default(now()) @map("created_at")
  submission    FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field         FormField?     @relation(fields: [fieldId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([fieldKey])
  @@map("form_submission_values")
}

model FormAttachment {
  id           String         @id @default(cuid())
  submissionId String         @map("submission_id")
  fieldKey     String?        @map("field_key")
  fileName     String         @map("file_name")
  fileUrl      String?        @map("file_url")
  createdAt    DateTime       @default(now()) @map("created_at")
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("form_attachments")
}

model FormSignature {
  id           String         @id @default(cuid())
  submissionId String         @map("submission_id")
  fieldKey     String?        @map("field_key")
  signerName   String         @map("signer_name")
  signedAt     DateTime       @default(now()) @map("signed_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("form_signatures")
}

