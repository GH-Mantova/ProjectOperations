  insurances         EntityInsurance[]       @relation("SubInsurances")
  creditApplications CreditApplication[]     @relation("SubCreditApps")
  creditEntries      SupplierCreditEntry[]   @relation("SupplierCreditEntries")
  rateTables         RateTable[]             @relation("RateTableSupplier")

  @@index([entityType])
  @@index([prequalStatus])
  @@index([isActive])
  @@map("subcontractor_suppliers")
}

// NOTE: SubcontractorContact was unified into the polymorphic Contact model in
// PR #75 — rows were copied into `contacts` then. The legacy
// `subcontractor_contacts` table was dropped in PR #78
// (migration 20260426_feat_drop_deprecated_tables).

model EntityLicence {
