// Per-user personal AI provider keys. The key column is encrypted with the
// same aes-256-gcm/iv.tag.data envelope as PlatformConfig so secrets never
// sit in plaintext at rest. `isActive=false` lets a user keep a key on file
// without it appearing in the at-use picker.
model UserAiProvider {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String
  label          String?
  apiKey         String   @map("api_key")
  model          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, provider])
  @@map("user_ai_providers")
}

// Per-user recall of the last provider they picked, so the selector can
