  @@index([clientId])
  @@index([sourceJobId])
  @@map("projects")
}

// ── Daily Site Diary (ERP gap A) ──────────────────────────────────────────
// One diary per Project per calendar date — evidentiary spine for delay /
// variation / dispute defence. `lineItems` is a JSON array of loose entries
// (mixed categories such as delivery / visitor / event) so the site team can
// scale the form without a schema change; the top-level narrative fields
// (weather, crew, plant, deliveries, visitors, delays, notes) exist so the
// most-used shape stays queryable and rendered cleanly. `attachments` is a
// JSON array of `{ fileName, url, mimeType?, uploadedAt }`; a full document-
// control table can come later without touching this migration.
model DailyDiary {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteId       String?   @map("site_id")
  site         Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  date         DateTime  @db.Date
  authorId     String    @map("author_id")
  author       User      @relation("DailyDiaryAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  weather      String?
  temperatureC Decimal?  @map("temperature_c") @db.Decimal(4, 1)
  crewSummary  String?   @map("crew_summary")
  plantOnSite  String?   @map("plant_on_site")
  deliveries   String?
  visitors     String?
  delays       String?
  notes        String?
  lineItems    Json      @default("[]") @map("line_items")
  attachments  Json      @default("[]")
  submittedAt  DateTime? @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([projectId, date])
  @@index([projectId, date])
  @@index([siteId])
  @@index([authorId])
  @@map("daily_diaries")
}

model ProjectScopeItem {
