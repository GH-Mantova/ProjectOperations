model Asset {
  id                       String                  @id @default(cuid())
  assetCategoryId          String?                 @map("asset_category_id")
  resourceTypeId           String?                 @map("resource_type_id")
  name                     String
  assetCode                String                  @unique @map("asset_code")
  serialNumber             String?                 @unique @map("serial_number")
  // Barcode / QR tag support (AssetTiger parity). Both nullable and additive.
  // barcode — 1D barcode value (e.g. Code128, QR string scanned as plain text).
  // qrValue — canonical QR payload; if set, the web UI renders a QR image.
  // Scan lookup endpoint matches barcode OR qrValue OR assetCode (fallback).
  barcode                  String?                 @unique @map("barcode")
  qrValue                  String?                 @unique @map("qr_value")
  status                   String                  @default("AVAILABLE")
  homeBase                 String?                 @map("home_base")
  currentLocation          String?                 @map("current_location")
  notes                    String?
  // Waste transport cost engine R3 T-0 (2026-07-15).
  // fuelConsumptionLPer100km — per-truck rate (Marco: fuel burn is a truck
  // property, not a material property). nominalLoadTonnes is a fallback used
  // only when the per-material Transport Capacity reference table has no row
  // for this asset's transport type × the SoW line's material class.
  // Both nullable → additive. Resolver falls back to AssetCategory defaults.
  fuelConsumptionLPer100km Decimal?                @map("fuel_consumption_l_per_100km") @db.Decimal(6, 2)
  nominalLoadTonnes        Decimal?                @map("nominal_load_tonnes") @db.Decimal(8, 2)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  category                 AssetCategory?          @relation(fields: [assetCategoryId], references: [id], onDelete: SetNull)
  resourceType             ResourceType?           @relation(fields: [resourceTypeId], references: [id], onDelete: SetNull)
  shiftAssignments         ShiftAssetAssignment[]
  maintenancePlans         AssetMaintenancePlan[]
  maintenanceEvents        AssetMaintenanceEvent[]
  inspections              AssetInspection[]
  breakdowns               AssetBreakdown[]
  statusHistory            AssetStatusHistory[]
  formSubmissions          FormSubmission[]
  allocations              ProjectAllocation[]
  scheduleAllocations      ScheduleAllocation[]
  scopePlantRefs           ScopeOfWorksItem[]      @relation("ScopeItemPlant")
  dockets                  Docket[]
  checkouts                AssetCheckout[]

  @@index([status])
  @@index([assetCategoryId])
  @@index([resourceTypeId])
  @@map("assets")
}

// AssetCheckout — custody chain record. Retires the Jotform "Grice Office Key Checkout"
// form: every check-out and check-in is now tracked here instead of Jotform.
// Service-layer guard enforces "at most one open checkout per asset" (checkedInAt IS NULL).
// Prisma cannot enforce partial uniqueness portably, so the check is in AssetsService.checkoutAsset.
model AssetCheckout {
  id              String    @id @default(cuid())
  assetId         String    @map("asset_id")
  // Holder: at most one of holderWorkerId / holderUserId / siteId / jobId is typically set,
  // but any combination is allowed (e.g. asset on a job at a specific site).
  holderWorkerId  String?   @map("holder_worker_id")
  holderUserId    String?   @map("holder_user_id")
  siteId          String?   @map("site_id")
  jobId           String?   @map("job_id")
  checkedOutAt    DateTime  @default(now()) @map("checked_out_at")
  dueBackAt       DateTime? @map("due_back_at")
  checkedInAt     DateTime? @map("checked_in_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  holderWorker    Worker?   @relation("AssetCheckoutHolderWorker", fields: [holderWorkerId], references: [id], onDelete: SetNull)
  holderUser      User?     @relation("AssetCheckoutHolderUser", fields: [holderUserId], references: [id], onDelete: SetNull)
  site            Site?     @relation("AssetCheckoutSite", fields: [siteId], references: [id], onDelete: SetNull)
  job             Job?      @relation("AssetCheckoutJob", fields: [jobId], references: [id], onDelete: SetNull)

  // Index for fast "open checkout" lookup (checkedInAt IS NULL rows).
  @@index([assetId, checkedInAt])
  @@index([holderWorkerId])
  @@index([holderUserId])
  @@map("asset_checkouts")
}

