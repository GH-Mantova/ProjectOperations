// ─── Worker availability (PR #85) ─────────────────────────────────────────
// Two distinct concepts:
//   WorkerLeave         — approved time off with type (annual/sick/personal/...)
//   WorkerUnavailability — soft holds for recurring or ad-hoc days the worker
//                          cannot be allocated (e.g. RDO, training, ticket renewal)
// Scheduler reads both and overlays them on the calendar; create-shift flow
// surfaces conflicts so the planner can re-pick a worker without committing.

model WorkerLeave {
  id              String        @id @default(cuid())
  workerProfileId String        @map("worker_profile_id")
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  leaveType       String        @map("leave_type")
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  status          String        @default("PENDING")
  notes           String?
  requestedById   String?       @map("requested_by_id")
  requestedBy     User?         @relation("WorkerLeaveRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedById    String?       @map("approved_by_id")
  approvedBy      User?         @relation("WorkerLeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?     @map("approved_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([workerProfileId, startDate])
  @@index([status])
  @@map("worker_leaves")
}

model WorkerUnavailability {
  id              String        @id @default(cuid())
  workerProfileId String        @map("worker_profile_id")
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reason          String
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  recurringDay    Int?          @map("recurring_day")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([workerProfileId, startDate])
  @@map("worker_unavailability")
}

// ─── GPS clock-on (PR #84) ────────────────────────────────────────────────
// One row per geolocation reading associated with a clock-on or clock-off
// event. We log raw points (separate from the timesheet snapshot) so audits
