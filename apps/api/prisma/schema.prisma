generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthcheckSeedMarker {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("healthcheck_seed_markers")
}

model User {
  id                         String                      @id @default(cuid())
  email                      String                      @unique
  firstName                  String                      @map("first_name")
  lastName                   String                      @map("last_name")
  passwordHash               String                      @map("password_hash")
  isActive                   Boolean                     @default(true) @map("is_active")
  isSuperUser                Boolean                     @default(false) @map("is_super_user")
  ssoOnly                    Boolean                     @default(false) @map("sso_only")
  forcePasswordReset         Boolean                     @default(false) @map("force_password_reset")
  lastLoginAt                DateTime?                   @map("last_login_at")
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  createdById                String?                     @map("created_by_id")
  updatedById                String?                     @map("updated_by_id")
  managerId                  String?                     @map("manager_id")
  createdBy                  User?                       @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy                  User?                       @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  manager                    User?                       @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdUsers               User[]                      @relation("UserCreatedBy")
  updatedUsers               User[]                      @relation("UserUpdatedBy")
  directReports              User[]                      @relation("UserManager")
  userRoles                  UserRole[]
  refreshTokens              RefreshToken[]
  auditLogs                  AuditLog[]                  @relation("AuditActor")
  notifications              Notification[]
  dashboards                 Dashboard[]                 @relation("DashboardOwner")
  userDashboards             UserDashboard[]
  worker                     Worker?
  workerProfile              WorkerProfile?
  estimatedTenders           Tender[]                    @relation("TenderEstimator")
  assignedTenders            Tender[]                    @relation("TenderAssignedEstimator")
  tenderNotes                TenderNote[]                @relation("TenderNoteAuthor")
  tenderFollowUps            TenderFollowUp[]            @relation("TenderFollowUpAssignee")
  tenderEntriesAuthored      TenderEntry[]               @relation("TenderEntryAuthor")
  tenderEntriesAssigned      TenderEntry[]               @relation("TenderEntryAssignee")
  lockedTenderRateSets       TenderRateSet[]             @relation("TenderRateSetLockedBy")
  managedJobs                Job[]                       @relation("JobProjectManager")
  supervisedJobs             Job[]                       @relation("JobSupervisor")
  ownedActivities            JobActivity[]               @relation("JobActivityOwner")
  ledShifts                  Shift[]                     @relation("ShiftLead")
  reportedJobIssues          JobIssue[]                  @relation("JobIssueReporter")
  approvedVariations         JobVariation[]              @relation("JobVariationApprover")
  progressEntries            JobProgressEntry[]          @relation("JobProgressEntryAuthor")
  statusChanges              JobStatusHistory[]          @relation("JobStatusHistoryActor")
  formSubmissions            FormSubmission[]
  createdDocuments           DocumentLink[]              @relation("DocumentCreatedBy")
  updatedDocuments           DocumentLink[]              @relation("DocumentUpdatedBy")
  archivedCloseouts          JobCloseout[]               @relation("JobCloseoutArchivedBy")
  tenderClientNotes          TenderClientNote[]          @relation("TenderClientNoteAuthor")
  tenderScopeRevisions       TenderScopeRevision[]       @relation("TenderScopeRevisionAuthor")
  projectsManaged            Project[]                   @relation("ProjectManager")
  projectsSupervised         Project[]                   @relation("ProjectSupervisor")
  projectsEstimated          Project[]                   @relation("ProjectEstimator")
  projectsWhs                Project[]                   @relation("ProjectWHS")
  projectsCreated            Project[]                   @relation("ProjectCreatedBy")
  projectActivityLogs        ProjectActivityLog[]
  projectAllocationsCreated  ProjectAllocation[]         @relation("ProjectAllocationCreatedBy")
  scheduleAllocationsCreated ScheduleAllocation[]        @relation("ScheduleAllocationCreatedBy")
  competencyOverrides        CompetencyOverride[]        @relation("CompetencyOverrideActor")
  approvedTimesheets         Timesheet[]                 @relation("TimesheetApprover")
  rejectedTimesheets         Timesheet[]                 @relation("TimesheetRejecter")
  approvedWorkerLeaves       WorkerLeave[]               @relation("WorkerLeaveApprover")
  requestedWorkerLeaves      WorkerLeave[]               @relation("WorkerLeaveRequester")
  formApprovalAssignments    FormApproval[]              @relation("FormApprovalAssignee")
  formScheduleAssignments    FormSchedule[]              @relation("FormScheduleAssignee")
  scopeItemsCreated          ScopeOfWorksItem[]          @relation("ScopeOfWorksCreatedBy")
  estimateExports            EstimateExport[]
  globalListsCreated         GlobalList[]                @relation("GlobalListCreatedBy")
  listItemsCreated           GlobalListItem[]            @relation("GlobalListItemCreatedBy")
  clarificationNotesCreated  TenderClarificationNote[]   @relation("TenderClarificationNoteAuthor")
  cuttingSheetItemsCreated   CuttingSheetItem[]          @relation("CuttingSheetItemCreatedBy")
  emailProviderConfigUpdates EmailProviderConfig[]
  contractsCreated           Contract[]                  @relation("ContractCreatedBy")
  variationsCreated          Variation[]                 @relation("VariationCreatedBy")
  progressClaimsCreated      ProgressClaim[]             @relation("ProgressClaimCreatedBy")
  createdQuotes              ClientQuote[]               @relation("QuoteCreatedBy")
  sentQuotes                 ClientQuote[]               @relation("QuoteSentBy")
  sentQuoteEmails            QuoteEmail[]                @relation("QuoteEmailSentBy")
  sentCorrespondence         CorrespondenceMessage[]     @relation("CorrespondenceSentBy")
  tenderFilterPresets        TenderFilterPreset[]
  scopeWasteItemsCreated     ScopeWasteItem[]            @relation("ScopeWasteItemCreatedBy")
  scopeCardsCreated          ScopeCard[]                 @relation("ScopeCardCreatedBy")
  subcontractorsCreated      SubcontractorSupplier[]     @relation("SubcontractorCreatedBy")
  subcontractorDocsUploaded  SubcontractorDocument[]     @relation("SubDocUploadedBy")
  creditAppsCreated          CreditApplication[]         @relation("CreditAppCreator")
  creditAppsReviewed         CreditApplication[]         @relation("CreditAppReviewer")
  supplierCreditEntries      SupplierCreditEntry[]       @relation("SupplierCreditEntryCreator")
  contactsCreated            Contact[]                   @relation("ContactCreatedBy")
  clientsAsClaimReminder     Client[]                    @relation("ClaimReminderUser")
  qualificationsCreated      WorkerQualification[]       @relation("QualificationCreatedBy")
  complianceAlertsSent       ComplianceAlert[]           @relation("ComplianceAlertRecipient")
  safetyIncidentsReported    SafetyIncident[]            @relation("SafetyIncidentReporter")
  safetyIncidentsClosed      SafetyIncident[]            @relation("SafetyIncidentCloser")
  hazardsReported            HazardObservation[]         @relation("HazardReporter")
  hazardsAssigned            HazardObservation[]         @relation("HazardAssignee")
  personaInstructionUpdates  PersonaCompanyInstruction[] @relation("PersonaInstructionUpdater")
  personaSettings            UserPersonaSettings[]
  pilotFeedback              PilotFeedback[]             @relation("PilotFeedbackUser")

  // Comms + Approvals Phase 2 slice 1 — record-anchored internal messages
  // and approval-decision audit. Overrule paths resolve through the
  // managerId chain above and the authority seam; these are the storage side.
  sentInternalMessages     InternalMessage[]  @relation("InternalMessageSender")
  receivedInternalMessages InternalMessage[]  @relation("InternalMessageRecipient")
  approvalDecisions        ApprovalDecision[] @relation("ApprovalDecidedBy")

  // §5A.1 PR 9 — per-user encrypted AI provider keys (BYOK). Storage format
  // is "<iv-base64>:<authTag-base64>:<ciphertext-base64>" produced by
  // KeyEncryptionService (AES-256-GCM, BYOK_ENCRYPTION_KEY master). Presence
  // of an encrypted column is the source of truth for "this user has a key
  // for this provider"; validatedAt records the last successful live test.
  anthropicKeyEncrypted   String?   @map("anthropic_key_encrypted")
  anthropicKeyValidatedAt DateTime? @map("anthropic_key_validated_at")
  openaiKeyEncrypted      String?   @map("openai_key_encrypted")
  openaiKeyValidatedAt    DateTime? @map("openai_key_validated_at")
  geminiKeyEncrypted      String?   @map("gemini_key_encrypted")
  geminiKeyValidatedAt    DateTime? @map("gemini_key_validated_at")
  groqKeyEncrypted        String?   @map("groq_key_encrypted")
  groqKeyValidatedAt      DateTime? @map("groq_key_validated_at")

  // §5A.1 PR 10 — persona conversation history. Cascade delete on user
  // removal so we don't leave orphan chats behind.
  conversations Conversation[]

  // PR-216 — calendar sync (mock-mode) records the events the adapter
  // has "pushed" to the user's calendar so re-runs can update or
  // cancel them deterministically.
  calendarSyncedEvents CalendarSyncedEvent[] @relation("CalendarSyncedEventUser")

  // Client-version telemetry — admin can nudge a specific user to reload.
  // Cleared automatically once the client reports the current server SHA.
  updateRequestedAt DateTime?       @map("update_requested_at")
  clientSessions    ClientSession[]

  @@index([isActive])
  @@index([managerId])
  @@map("users")
}

model ClientSession {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  clientVersion String   @map("client_version")
  userAgent     String?  @map("user_agent")
  firstSeenAt   DateTime @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientVersion])
  @@index([userId])
  @@index([lastSeenAt])
  @@map("client_sessions")
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  dashboards      Dashboard[]      @relation("DashboardOwnerRole")

  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String
  module          String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// Gated Entra SSO — a valid Entra token whose email has no active internal
// user does NOT get auto-provisioned; the user submits an access request
// which lands here for an admin to Approve (creates the user) or Deny.
// `kind` is the discriminator that lets a future field-worker email
// channel share this table without a migration.
model AccessRequest {
  id            String    @id @default(cuid())
  email         String
  displayName   String?   @map("display_name")
  entraOid      String?   @map("entra_oid")
  kind          String    @default("OFFICE") // OFFICE = Entra SSO (now) | FIELD = personal-email site worker (future)
  message       String?
  status        String    @default("PENDING") // PENDING | APPROVED | DENIED
  createdAt     DateTime  @default(now()) @map("created_at")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewedById  String?   @map("reviewed_by_id")
  createdUserId String?   @map("created_user_id")

  @@index([status])
  @@map("access_requests")
}

model SharePointFolderLink {
  id               String               @id @default(cuid())
  siteId           String               @map("site_id")
  driveId          String               @map("drive_id")
  itemId           String               @map("item_id")
  name             String
  relativePath     String               @map("relative_path")
  module           String
  linkedEntityType String?              @map("linked_entity_type")
  linkedEntityId   String?              @map("linked_entity_id")
  metadata         Json?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  files            SharePointFileLink[]
  documents        DocumentLink[]
  tenderDocuments  TenderDocumentLink[]

  @@unique([siteId, driveId, itemId])
  @@index([module])
  @@index([linkedEntityType, linkedEntityId])
  @@map("sharepoint_folder_links")
}

model SharePointFileLink {
  id               String                @id @default(cuid())
  folderLinkId     String?               @map("folder_link_id")
  siteId           String                @map("site_id")
  driveId          String                @map("drive_id")
  itemId           String                @map("item_id")
  name             String
  relativePath     String                @map("relative_path")
  webUrl           String                @map("web_url")
  mimeType         String?               @map("mime_type")
  sizeBytes        Int?                  @map("size_bytes")
  versionLabel     String?               @map("version_label")
  versionNumber    Int?                  @map("version_number")
  linkedEntityType String?               @map("linked_entity_type")
  linkedEntityId   String?               @map("linked_entity_id")
  metadata         Json?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  folderLink       SharePointFolderLink? @relation(fields: [folderLinkId], references: [id], onDelete: SetNull)
  documents        DocumentLink[]
  tenderDocuments  TenderDocumentLink[]

  @@unique([siteId, driveId, itemId])
  @@index([folderLinkId])
  @@index([linkedEntityType, linkedEntityId])
  @@map("sharepoint_file_links")
}

model DocumentLink {
  id                String                @id @default(cuid())
  linkedEntityType  String                @map("linked_entity_type")
  linkedEntityId    String                @map("linked_entity_id")
  module            String
  category          String
  status            String                @default("ACTIVE")
  title             String
  description       String?
  versionLabel      String?               @map("version_label")
  versionNumber     Int                   @default(1) @map("version_number")
  documentFamilyKey String?               @map("document_family_key")
  isCurrentVersion  Boolean               @default(true) @map("is_current_version")
  supersededAt      DateTime?             @map("superseded_at")
  folderLinkId      String?               @map("folder_link_id")
  fileLinkId        String?               @map("file_link_id")
  createdById       String?               @map("created_by_id")
  updatedById       String?               @map("updated_by_id")
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  folderLink        SharePointFolderLink? @relation(fields: [folderLinkId], references: [id], onDelete: SetNull)
  fileLink          SharePointFileLink?   @relation(fields: [fileLinkId], references: [id], onDelete: SetNull)
  createdBy         User?                 @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?                 @relation("DocumentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  tags              DocumentTag[]
  accessRules       DocumentAccessRule[]

  @@index([linkedEntityType, linkedEntityId])
  @@index([module])
  @@index([category])
  @@index([documentFamilyKey, versionNumber])
  @@index([status, isCurrentVersion])
  @@map("document_links")
}

model DocumentTag {
  id             String       @id @default(cuid())
  documentLinkId String       @map("document_link_id")
  tag            String
  createdAt      DateTime     @default(now()) @map("created_at")
  document       DocumentLink @relation(fields: [documentLinkId], references: [id], onDelete: Cascade)

  @@unique([documentLinkId, tag])
  @@index([tag])
  @@map("document_tags")
}

model DocumentAccessRule {
  id             String       @id @default(cuid())
  documentLinkId String       @map("document_link_id")
  accessType     String       @map("access_type")
  roleName       String?      @map("role_name")
  permissionCode String?      @map("permission_code")
  canView        Boolean      @default(true) @map("can_view")
  canDownload    Boolean      @default(true) @map("can_download")
  canOpenLink    Boolean      @default(true) @map("can_open_link")
  createdAt      DateTime     @default(now()) @map("created_at")
  document       DocumentLink @relation(fields: [documentLinkId], references: [id], onDelete: Cascade)

  @@index([accessType])
  @@index([roleName])
  @@index([permissionCode])
  @@map("document_access_rules")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  body      String
  severity  String
  status    String    @default("UNREAD")
  linkUrl   String?   @map("link_url")
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("notifications")
}

// ─── Comms + Approvals Phase 2 slice 1 ──────────────────────────────────
// Record-anchored internal message. `entityType`/`entityId` name the
// business record the message is about (e.g. Tender/tender-123). Reads are
// gated on the caller (either sender or recipient); writes on ownership
// (sender/recipient can mark read for their own copy).
model InternalMessage {
  id          String    @id @default(cuid())
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id")
  senderId    String    @map("sender_id")
  recipientId String    @map("recipient_id")
  subject     String?
  body        String
  status      String    @default("UNREAD")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  sender    User @relation("InternalMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("InternalMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status])
  @@index([entityType, entityId])
  @@map("internal_messages")
}

// Immutable audit of an approval decision. `action` is the authority seam
// action key (matches AuthorityService.check). Overrules point at the
// prior decision via `overrulesId`; the overruler must be senior in the
// `managerId` chain of the prior decider (enforced by ApprovalsService).
enum ApprovalDecisionKind {
  APPROVED
  REJECTED
  OVERRULED
}

model ApprovalDecision {
  id              String               @id @default(cuid())
  entityType      String               @map("entity_type")
  entityId        String               @map("entity_id")
  action          String
  amount          Decimal?             @db.Decimal(14, 2)
  decision        ApprovalDecisionKind
  reason          String?
  decidedById     String               @map("decided_by_id")
  overrulesId     String?              @unique @map("overrules_id")
  authorityRuleId String?              @map("authority_rule_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  decidedBy   User              @relation("ApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: Cascade)
  overrules   ApprovalDecision? @relation("ApprovalOverrules", fields: [overrulesId], references: [id])
  overruledBy ApprovalDecision? @relation("ApprovalOverrules")

  @@index([entityType, entityId])
  @@index([decidedById])
  @@index([action])
  @@map("approval_decisions")
}

model SearchEntry {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  title      String
  subtitle   String?
  body       String?
  module     String
  url        String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([module])
  @@index([entityType, entityId])
  @@map("search_entries")
}

model Dashboard {
  id          String            @id @default(cuid())
  name        String
  description String?
  scope       String
  ownerUserId String?           @map("owner_user_id")
  ownerRoleId String?           @map("owner_role_id")
  isDefault   Boolean           @default(false) @map("is_default")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  ownerUser   User?             @relation("DashboardOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerRole   Role?             @relation("DashboardOwnerRole", fields: [ownerRoleId], references: [id], onDelete: SetNull)
  widgets     DashboardWidget[]

  @@index([scope])
  @@index([ownerUserId])
  @@index([ownerRoleId])
  @@map("dashboards")
}

model DashboardWidget {
  id          String    @id @default(cuid())
  dashboardId String    @map("dashboard_id")
  type        String
  title       String
  description String?
  position    Int
  width       Int       @default(1)
  height      Int       @default(1)
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId, position])
  @@map("dashboard_widgets")
}

model Client {
  id                  String                    @id @default(cuid())
  name                String
  code                String?                   @unique
  status              String                    @default("ACTIVE")
  email               String?
  phone               String?
  notes               String?
  tradingName         String?                   @map("trading_name")
  businessType        String?                   @default("company") @map("business_type")
  abn                 String?
  acn                 String?
  gstRegistered       Boolean                   @default(true) @map("gst_registered")
  legalName           String?                   @map("legal_name")
  country             String                    @default("Australia")
  paymentTermsDay     Int?                      @map("payment_terms_day")
  paymentTermsType    String?                   @map("payment_terms_type")
  industry            String?
  website             String?
  physicalAddress     String?                   @map("physical_address")
  physicalSuburb      String?                   @map("physical_suburb")
  physicalState       String?                   @default("QLD") @map("physical_state")
  physicalPostcode    String?                   @map("physical_postcode")
  postalAddress       String?                   @map("postal_address")
  postalSuburb        String?                   @map("postal_suburb")
  postalState         String?                   @map("postal_state")
  postalPostcode      String?                   @map("postal_postcode")
  postalSameAs        Boolean                   @default(true) @map("postal_same_as")
  paymentTermsDays    Int?                      @default(30) @map("payment_terms_days")
  creditLimit         Decimal?                  @map("credit_limit") @db.Decimal(12, 2)
  creditApproved      Boolean                   @default(false) @map("credit_approved")
  preferredPayment    String?                   @map("preferred_payment")
  bankName            String?                   @map("bank_name")
  bankAccountName     String?                   @map("bank_account_name")
  bankBsb             String?                   @map("bank_bsb")
  bankAccountNumber   String?                   @map("bank_account_number")
  xeroContactId       String?                   @map("xero_contact_id")
  myobCardId          String?                   @map("myob_card_id")
  isActive            Boolean                   @default(true) @map("is_active")
  onHold              Boolean                   @default(false) @map("on_hold")
  onHoldReason        String?                   @map("on_hold_reason")
  internalNotes       String?                   @map("internal_notes")
  claimCutoffDay      Int?                      @map("claim_cutoff_day")
  claimReminderUserId String?                   @map("claim_reminder_user_id")
  claimReminderUser   User?                     @relation("ClaimReminderUser", fields: [claimReminderUserId], references: [id], onDelete: SetNull)
  preferenceScore     Int?                      @map("preference_score")
  winCount            Int                       @default(0) @map("win_count")
  tenderCount         Int                       @default(0) @map("tender_count")
  winRate             Decimal?                  @map("win_rate") @db.Decimal(5, 2)
  lastTenderAt        DateTime?                 @map("last_tender_at")
  lastWonAt           DateTime?                 @map("last_won_at")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  sites               Site[]
  tenderClients       TenderClient[]
  jobs                Job[]
  projects            Project[]
  formSubmissions     FormSubmission[]
  tenderClientNotes   TenderClientNote[]
  clientQuotes        ClientQuote[]
  licences            EntityLicence[]           @relation("ClientLicences")
  insurances          EntityInsurance[]         @relation("ClientInsurances")
  creditApplications  CreditApplication[]       @relation("ClientCreditApps")
  portalUsers         ClientPortalUser[]
