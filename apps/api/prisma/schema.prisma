  postcode        String?
  // ERP gap C — canonical site coordinates. Populated by admin when a
  // geofence is drawn; the SiteGeofence rows carry their own centres, so a
  // site can host multiple named geofences (e.g. main gate + laydown yard).
  centreLat       Decimal?         @map("centre_lat") @db.Decimal(9, 6)
  centreLng       Decimal?         @map("centre_lng") @db.Decimal(9, 6)
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
