// Haulage / Delivery Dockets (feat/erp-haulage-dockets).
// Digital docket capture for drivers in the field (skip-bin/waste cartage,
// plant hire). Mirrors Assignar docket workflow. DocketNumberSequence issues
// atomic sequential DKT-NNNNNN numbers, same pattern as SafetyIncident.
enum DocketType {
  DELIVERY
  HAULAGE
  DISPOSAL
}

model DocketNumberSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("docket_number_sequences")
}

model Docket {
  id           String     @id @default(cuid())
  docketNumber String     @unique @map("docket_number")
  type         DocketType

  jobId    String? @map("job_id")
  job      Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assetId  String? @map("asset_id")
  asset    Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  workerId String  @map("worker_id")
  worker   Worker  @relation(fields: [workerId], references: [id], onDelete: Restrict)

  materialWasteType String?  @map("material_waste_type")
