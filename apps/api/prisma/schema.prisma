// ─── Forms Content Snippet Library (PR forms-content-library) ──────────────
// Stores reusable HTML blocks (legal text, T&Cs, privacy notices, etc.) that
// can be referenced from FormField rows via snippetCode. Authoring happens
// once; every form field with fieldType="content_block" that carries a
// snippetCode is resolved at template-fetch time.

model FormContentSnippet {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
