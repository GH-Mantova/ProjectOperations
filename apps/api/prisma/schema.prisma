  // PR #97 â€" generic field config + per-field rule attachments
  // config: field-type-specific settings (min/max/step, formula, lookup spec, etc.)
  // conditions: array of FieldRule objects evaluated by RulesEngineService
  // validations: extra validation rules beyond isRequired
  // actions: on_change actions (set_value, show, hide, send_notification, create_record)
  isReadOnly   Boolean               @default(false) @map("is_read_only")
  defaultValue String?               @map("default_value")
  config       Json                  @default("{}")
  conditions   Json                  @default("[]")
  validations  Json                  @default("[]")
  actions      Json                  @default("[]")
  // PR forms-content-library: when fieldType is "content_block", this
  // code references a FormContentSnippet.code for resolved HTML rendering.
  // A soft reference (no FK) so snippet deletion never blocks form edits.
  snippetCode  String?               @map("snippet_code")
  createdAt    DateTime              @default(now()) @map("created_at")
  section      FormSection           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  values       FormSubmissionValue[]

  @@unique([sectionId, fieldKey])
  @@index([sectionId, fieldOrder])
  @@index([snippetCode])
  @@map("form_fields")
}

model FormRule {
  id              String              @id @default(cuid())
  versionId       String              @map("version_id")
  sourceFieldKey  String              @map("source_field_key")
  targetFieldKey  String              @map("target_field_key")
  operator        String
  comparisonValue String?             @map("comparison_value")
  effect          String              @default("SHOW")
  createdAt       DateTime            @default(now()) @map("created_at")
  version         FormTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("form_rules")
}

model FormSubmission {
  id                String                @id @default(cuid())
  templateVersionId String                @map("template_version_id")
  status            String                @default("SUBMITTED")
  submittedAt       DateTime              @default(now()) @map("submitted_at")
  submittedById     String?               @map("submitted_by_id")
  jobId             String?               @map("job_id")
  clientId          String?               @map("client_id")
  assetId           String?               @map("asset_id")
  workerId          String?               @map("worker_id")
  siteId            String?               @map("site_id")
  shiftId           String?               @map("shift_id")
  supplierName      String?               @map("supplier_name")
  geolocation       String?
  summary           String?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  templateVersion   FormTemplateVersion   @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  submittedBy       User?                 @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  job               Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  client            Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset             Asset?                @relation(fields: [assetId], references: [id], onDelete: SetNull)
  worker            Worker?               @relation(fields: [workerId], references: [id], onDelete: SetNull)
  site              Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  shift             Shift?                @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  values            FormSubmissionValue[]
  attachments       FormAttachment[]
  signatures        FormSignature[]
  // PR #97 -- auto-populated context blob, GPS lat/lng, approval chain rows,
  // and links back to records auto-created by submit-time actions
  context           Json                  @default("{}")
  gpsLat            Decimal?              @map("gps_lat") @db.Decimal(10, 7)
  gpsLng            Decimal?              @map("gps_lng") @db.Decimal(10, 7)
  approvals         FormApproval[]
  triggeredRecords  FormTriggeredRecord[]
  punchItems        PunchItem[]
  correctiveActions CorrectiveAction[]
  // Inspection scoring (this PR). Computed by FormsEngineService.submitForm
  // from field-level scoreConfig weights and choice-level response-set
  // scores. `score` and `maxScore` are the achieved and possible weighted
  // sums; `scorePct` is (score / maxScore * 100) rounded to two decimals;
  // `outcome` is one of PASS/FAIL/PARTIAL/NA vs the template's
  // `settings.passThresholdPct`. All null when scoring is not configured.
  score             Decimal?              @db.Decimal(10, 2)
  maxScore          Decimal?              @map("max_score") @db.Decimal(10, 2)
  scorePct          Decimal?              @map("score_pct") @db.Decimal(5, 2)
  outcome           String?
  // PR #621 -- public/kiosk submissions link back to the originating token
  publicLinkId      String?               @map("public_link_id")
  publicLink        FormPublicLink?       @relation(fields: [publicLinkId], references: [id], onDelete: SetNull)

  @@index([templateVersionId, submittedAt])
  @@index([jobId])
  @@index([assetId])
  @@index([workerId])
  @@index([shiftId])
  @@index([outcome])
  @@index([publicLinkId])
  @@map("form_submissions")
}

