  // kind values: "signature" | "photo" | "weighbridge"
  kind       String
  storageUrl String   @map("storage_url")
  mimeType   String?  @map("mime_type")
  capturedAt DateTime @map("captured_at")

  @@index([docketId])
  @@map("docket_attachments")
