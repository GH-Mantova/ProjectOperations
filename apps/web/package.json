{
  "name": "@project-ops/web",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --configLoader native --host 127.0.0.1 --port 4173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:logic": "tsc -p tsconfig.tendering-smoke.json && node .tmp-smoke/pages/tendering-page-helpers.smoke.js",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@azure/msal-browser": "^5.7.0",
    "@azure/msal-react": "^5.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@project-ops/ui": "workspace:*",
    "@tanstack/react-query": "^5.66.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.8.2",
    "vite": "^6.4.2",
    "vitest": "^3.0.8"
  }
}
