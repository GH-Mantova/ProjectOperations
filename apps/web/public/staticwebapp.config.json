{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/data-model.html",
      "/*.{css,js,mjs,map,ico,png,jpg,jpeg,gif,svg,webp,avif,json,txt,xml,woff,woff2,ttf,otf,webmanifest}"
    ]
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/sw.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/registerSW.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/manifest.webmanifest",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/version.json",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/workbox-*.js",
      "headers": { "Cache-Control": "no-cache, must-revalidate" }
    },
    {
      "route": "/assets/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    }
  ]
}
