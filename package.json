{
  "name": "project-operations-platform",
  "private": true,
  "version": "0.1.3",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @project-ops/api --filter @project-ops/web dev",
    "dev:api": "pnpm --filter @project-ops/api dev",
    "dev:api:e2e": "cross-env CORS_ORIGIN=http://127.0.0.1:4173 pnpm --filter @project-ops/api exec node dist/src/main.js",
    "dev:web": "pnpm --filter @project-ops/web dev",
    "dev:web:e2e": "cross-env VITE_API_BASE_URL=http://127.0.0.1:3000/api/v1 pnpm --filter @project-ops/web dev:e2e",
    "build": "pnpm -r build",
    "build:azure": "pnpm --filter @project-ops/web build && pnpm --filter @project-ops/api build",
    "start:azure": "pnpm --filter @project-ops/api start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:api:serial": "pnpm --filter @project-ops/api test:serial",
    "test:web:logic": "pnpm --filter @project-ops/web test:logic",
    "test:tendering:e2e": "playwright test tests/e2e/tendering.spec.ts",
    "test:tendering:e2e:reuse": "playwright test tests/e2e/tendering.spec.ts --config=playwright.reuse.config.ts",
    "format": "pnpm -r format",
    "prisma:generate": "pnpm --filter @project-ops/api prisma:generate",
    "prisma:migrate": "pnpm --filter @project-ops/api prisma:migrate",
    "seed": "pnpm --filter @project-ops/api seed",
    "compliance:smoke": "pnpm --filter @project-ops/api compliance:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "cross-env": "^10.1.0",
    "playwright": "^1.59.1"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0"
    }
  }
}
