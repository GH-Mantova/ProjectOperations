{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@project-ops/ui/*": [
        "./packages/ui/src/*"
      ],
      "@project-ops/config/*": [
        "./packages/config/src/*"
      ]
    }
  }
}
